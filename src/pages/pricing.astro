---
import MainLayout from '../layouts/MainLayout.astro';

interface Renders { hourly: string; daily: string; monthly: string; }
interface Cache { size: string; ttl: string; }
interface Indicator { label: string; note: string; }
interface Tier {
  id: string; name: string; cost: string; costNote: string; desc: string;
  features?: string[]; qualifyBy?: string[];
  cta: { label: string; href: string };
  renders?: Renders | null; cache?: Cache | null; indicator?: Indicator | null;
  coming: boolean;
}
interface PricingSection { id: string; label: string; intro: string; tiers: Tier[]; }

const sections: PricingSection[] = [
  {
    id: 'hosted',
    label: 'Hosted Service',
    intro: 'Thumbrella processes thumbnails on shared infrastructure. A registered account works across the hosted API, self-hosted instances, and AI platforms.',
    tiers: [
      {
        id: 'free',
        name: 'Free',
        cost: '$0',
        costNote: 'register',
        desc: 'A registered account adds distributed caching and a usage dashboard to any Thumbrella setup — hosted, self-hosted, or platform-based.',
        features: [
          'Shared distributed cache — works with any client library or hosting method',
          'Usage tracking dashboard',
        ],
        cta: { label: 'Create an account', href: '/docs/getting-started/online-service' },
        renders: { hourly: '500', daily: '1,000', monthly: '~30k' },
        cache: { size: '10 MB', ttl: '5 days' },
        coming: false,
      },
      {
        id: 'fan',
        name: 'Fan',
        cost: 'Free',
        costNote: 'show some support',
        desc: 'Triple your limits in exchange for a small show of support. Qualify with any one:',
        qualifyBy: [
          'Star on GitHub, Docker Hub, or Product Hunt',
          'Order a piece of Thumbrella merch',
        ],
        cta: { label: 'Coming soon', href: 'https://github.com/thumbrella/thumbrella' },
        renders: { hourly: '1,500', daily: '3,000', monthly: '~90k' },
        cache: { size: '30 MB', ttl: '15 days' },
        coming: true,
      },
      {
        id: 'paid',
        name: 'Paid',
        cost: '$5',
        costNote: 'per month',
        desc: 'More control over auth, thumbnail output, and cache isolation. Upgrade when your project actually needs it.',
        features: [
          'Create separate API tokens with individual usage limits',
          'Control thumbnail settings — resolution, quality, output format',
          'Isolated caches with independent quota tracking',
          'Everything in Free',
        ],
        cta: { label: 'Get notified at launch', href: '/docs/getting-started/online-service' },
        renders: { hourly: '5,000', daily: '10,000', monthly: '~300k' },
        cache: { size: '200 MB', ttl: '150 days' },
        coming: false,
      },
      {
        id: 'paid-pro',
        name: 'Paid Pro',
        cost: '~$10',
        costNote: 'per month',
        desc: 'Higher limits for heavier workloads. Details to be determined closer to launch.',
        features: [
          'Everything in Paid',
          'Higher render caps',
          'More cache storage and longer TTL',
        ],
        cta: { label: 'Coming later', href: '/docs/getting-started/online-service' },
        renders: null,
        cache: null,
        indicator: { label: 'Higher limits', note: 'TBD' },
        coming: true,
      },
    ],
  },
  {
    id: 'self-run',
    label: 'Self-Run',
    intro: 'Install and operate Thumbrella on your own hardware or a third-party compute platform. Self-hosted users can still register a caching account to tap into the shared network.',
    tiers: [
      {
        id: 'self-hosted',
        name: 'Self-Hosted',
        cost: 'Free',
        costNote: 'open source',
        desc: 'Run the full Thumbrella server on your own hardware. No account required. Unlimited renders.',
        features: [
          'Single binary — or build from source',
          'Optional external executables for extended media format support',
          'Local caching with SQLite',
          'Optional: pair with a registered account for shared distributed cache access',
        ],
        cta: { label: 'Self-hosted docs', href: '/docs/getting-started/self-hosted' },
        renders: null,
        cache: null,
        indicator: { label: 'Unlimited renders', note: 'your hardware' },
        coming: false,
      },
      {
        id: 'ai-platforms',
        name: 'AI Platforms',
        cost: 'Free',
        costNote: '+ platform fees',
        desc: 'Use Thumbrella on Replicate and similar compute platforms at no added charge. Platform billing applies as normal.',
        features: [
          'No install — runs in the cloud',
          'Free and Paid caching accounts reduce redundant processing',
          'Cache usage charged against your registered account limits',
        ],
        cta: { label: 'AI platform docs', href: '/docs/getting-started/ai-platforms' },
        renders: null,
        cache: null,
        indicator: { label: 'Account limits apply', note: 'if registered' },
        coming: false,
      },
      {
        id: 'sponsored',
        name: 'Sponsored',
        cost: '~$100',
        costNote: 'per month',
        desc: 'A production-ready self-hosted deployment with enterprise-grade features, full offline capability, and priority support.',
        features: [
          'Docker image — full media type support out of the box',
          'Perpetual license with one full year of upgrades (works offline, no phone home)',
          'Listed on the Thumbrella sponsor page',
          'Email support',
          'Redis and other cache backends with maintenance tooling',
          'Optional: access the global distributed cache network',
          'Optional: access the hosted service with elevated quotas',
        ],
        cta: { label: 'Sponsor docs', href: '/docs/deployment/sponsor' },
        renders: null,
        cache: null,
        indicator: { label: 'Unlimited renders', note: 'your server' },
        coming: false,
      },
    ],
  },
];
---

<MainLayout title="Pricing — Thumbrella" description="Every way to use Thumbrella and what each costs.">
  <div class="pricing-page">
    <div class="container">

      <div class="pricing-disclaimer">
        <span class="disclaimer-icon" aria-hidden="true">⚠</span>
        Service not yet operational. Pricing and quotas are subject to change before launch.
      </div>

      <header class="pricing-header">
        <h1>Pricing</h1>
        <p>Start free. Upgrade when it makes sense — or run it yourself for nothing.</p>
      </header>

      {sections.map((section) => (
        <div class="pricing-section">
          <div class="pricing-section__header">
            <h2>{section.label}</h2>
            <p>{section.intro}</p>
          </div>
          <div class="pricing-rows">
            {section.tiers.map((tier) => (
              <div class:list={['tier-row', tier.coming && 'tier-row--coming']}>
                <div class="tier-identity">
                  <div class="tier-heading">
                    <span class="tier-name">{tier.name}</span>
                    {tier.coming && <span class="tier-coming-badge">coming soon</span>}
                    <span class="tier-cost">{tier.cost}</span>
                    <span class="tier-cost-note">/ {tier.costNote}</span>
                  </div>
                  <p class="tier-desc">{tier.desc}</p>
                  {tier.qualifyBy && (
                    <ul class="tier-qualify">
                      {tier.qualifyBy.map((q) => <li>{q}</li>)}
                    </ul>
                  )}
                  {tier.features && (
                    <ul class="tier-features">
                      {tier.features.map((f) => <li>{f}</li>)}
                    </ul>
                  )}
                  <a href={tier.cta.href} class="tier-cta">{tier.cta.label} →</a>
                </div>

                <div class="tier-metrics">
                  {tier.renders && (
                    <div class="metric-panel">
                      <h3 class="metric-panel__label">Renders</h3>
                      <div class="metric-panel__stats">
                        <div class="stat-row">
                          <span class="stat-value">{tier.renders.hourly}</span>
                          <span class="stat-unit">/ hour</span>
                        </div>
                        <div class="stat-row">
                          <span class="stat-value">{tier.renders.daily}</span>
                          <span class="stat-unit">/ day</span>
                        </div>
                        <div class="stat-row stat-row--muted">
                          <span class="stat-value">{tier.renders.monthly}</span>
                          <span class="stat-unit">/ month</span>
                        </div>
                      </div>
                    </div>
                  )}
                  {tier.cache && (
                    <div class="metric-panel">
                      <h3 class="metric-panel__label">Cache</h3>
                      <div class="metric-panel__stats">
                        <div class="stat-row">
                          <span class="stat-value">{tier.cache.size}</span>
                          <span class="stat-unit">stored</span>
                        </div>
                        <div class="stat-row">
                          <span class="stat-value">{tier.cache.ttl}</span>
                          <span class="stat-unit">TTL</span>
                        </div>
                      </div>
                    </div>
                  )}
                  {tier.indicator && !tier.renders && (
                    <div class="metric-chip">
                      <span class="metric-chip__label">{tier.indicator.label}</span>
                      <span class="metric-chip__note">{tier.indicator.note}</span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="pricing-notes">
        <div class="note-card">
          <h3>Renders vs. cache hits</h3>
          <p>A <em>render</em> is charged when Thumbrella processes a new media file. Serving an already-generated thumbnail — a cache hit — is always free at every tier.</p>
        </div>
        <div class="note-card">
          <h3>Hourly and daily caps</h3>
          <p>Limits apply per hour and per day — whichever comes first. When an account hits its cap, requests return a lightweight placeholder thumbnail rather than failing outright.</p>
        </div>
        <div class="note-card">
          <h3>Shared caching for self-run</h3>
          <p>Self-hosted and platform-based users can register a free or paid account to access the distributed cache network. Thumbnails cached from any source benefit everyone.</p>
        </div>
      </div>

    </div>
  </div>
</MainLayout>

<style>
  .pricing-page {
    padding: 3.5rem 0 6rem;
  }

  .pricing-disclaimer {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(203, 134, 22, 0.08);
    border: 1px solid rgba(203, 134, 22, 0.28);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.84rem;
    color: #e0b86a;
    margin-bottom: 2.5rem;
    line-height: 1.4;
  }

  .disclaimer-icon { flex-shrink: 0; }

  .pricing-header {
    margin-bottom: 2.5rem;
  }

  .pricing-header h1 {
    font-family: var(--font-sans);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .pricing-header p {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .pricing-section {
    margin-bottom: 2.5rem;
  }

  .pricing-section__header {
    margin-bottom: 0.85rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
  }

  .pricing-section__header h2 {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.3rem;
  }

  .pricing-section__header p {
    font-size: 0.84rem;
    color: var(--text-muted);
    margin: 0;
    max-width: 70ch;
    line-height: 1.5;
  }

  .pricing-rows {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tier-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 2rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem 1.4rem;
  }

  .tier-row--coming {
    opacity: 0.65;
  }

  .tier-heading {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.45rem;
    flex-wrap: wrap;
  }

  .tier-name {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }

  .tier-coming-badge {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(200, 149, 78, 0.38);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  .tier-cost {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent-strong);
  }

  .tier-cost-note {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .tier-desc {
    font-size: 0.84rem;
    color: var(--text-muted);
    margin: 0 0 0.55rem;
    line-height: 1.55;
    max-width: 52ch;
  }

  .tier-features,
  .tier-qualify {
    list-style: none;
    margin: 0 0 0.75rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tier-features li,
  .tier-qualify li {
    font-size: 0.82rem;
    color: var(--text-muted);
    padding-left: 1.1rem;
    position: relative;
    line-height: 1.45;
  }

  .tier-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .tier-qualify li::before {
    content: '·';
    position: absolute;
    left: 0.15rem;
    color: var(--accent);
    font-weight: 700;
  }

  .tier-cta {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s;
  }

  .tier-cta:hover { color: var(--accent-strong); }

  .tier-metrics {
    display: flex;
    gap: 0.6rem;
    flex-shrink: 0;
    align-items: start;
    padding-top: 0.1rem;
  }

  .metric-panel {
    background: rgba(0, 0, 0, 0.18);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.85rem;
    min-width: 106px;
  }

  .metric-panel__label {
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.4rem;
  }

  .metric-panel__stats {
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
  }

  .stat-row {
    display: flex;
    align-items: baseline;
    gap: 0.28rem;
  }

  .stat-value {
    font-family: var(--font-mono, 'IBM Plex Mono', monospace);
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--text);
  }

  .stat-unit {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .stat-row--muted .stat-value,
  .stat-row--muted .stat-unit {
    opacity: 0.38;
  }

  .metric-chip {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    background: rgba(0, 0, 0, 0.18);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.85rem;
    min-width: 106px;
  }

  .metric-chip__label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
  }

  .metric-chip__note {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .pricing-notes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .note-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.1rem;
  }

  .note-card h3 {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.4rem;
  }

  .note-card p {
    font-size: 0.81rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.55;
  }

  .note-card em {
    color: var(--text);
    font-style: normal;
  }
</style>
