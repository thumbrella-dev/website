<script>
  const el = document.getElementById('hero-typewriter');
  const sourceEl = document.getElementById('hero-typewriter-words');
  if (el) {
    const typewriterEl = el;
    const sourceWords = sourceEl?.textContent
      ?.split('|')
      .map((word) => word.trim())
      .filter(Boolean) ?? [];
    const words = sourceWords.length ? sourceWords : [el.textContent?.trim() || 'best'];
    let wordIndex = 0;
    let charIndex = words[0].length;
    let isDeleting = false;

    typewriterEl.textContent = words[0];

    function tick() {
      const current = words[wordIndex];

      if (!isDeleting && charIndex === current.length) {
        setTimeout(() => { isDeleting = true; tick(); }, 2000);
        return;
      }

      if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        setTimeout(tick, 300);
        return;
      }

      charIndex += isDeleting ? -1 : 1;
      typewriterEl.textContent = words[wordIndex].slice(0, charIndex);
      setTimeout(tick, isDeleting ? 40 : 80);
    }

    setTimeout(tick, 2000);
  }

  const tabButtons = Array.from(document.querySelectorAll('.run-modes__tab'));
  const tabPanels = Array.from(document.querySelectorAll('.run-mode-card'));

  if (tabButtons.length && tabPanels.length) {
    function selectTab(nextTab) {
      const targetPanelId = nextTab.getAttribute('data-panel');

      tabButtons.forEach((tab) => {
        const isActive = tab === nextTab;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
      });

      tabPanels.forEach((panel) => {
        const isActive = panel.id === targetPanelId;
        panel.classList.toggle('is-active', isActive);
        panel.hidden = !isActive;
        panel.setAttribute('tabindex', isActive ? '0' : '-1');
      });
    }

    tabButtons.forEach((tab, index) => {
      tab.addEventListener('click', () => selectTab(tab));

      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft' && event.key !== 'Home' && event.key !== 'End') {
          return;
        }

        event.preventDefault();

        let nextIndex = index;
        if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabButtons.length;
        if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabButtons.length) % tabButtons.length;
        if (event.key === 'Home') nextIndex = 0;
        if (event.key === 'End') nextIndex = tabButtons.length - 1;

        const nextTab = tabButtons[nextIndex];
        selectTab(nextTab);
        nextTab.focus();
      });
    });

    const initiallySelected = tabButtons.find((tab) => tab.getAttribute('aria-selected') === 'true') ?? tabButtons[0];
    selectTab(initiallySelected);
  }
</script>