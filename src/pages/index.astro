---
import MainLayout from '../layouts/MainLayout.astro';
import CapsItem from '../components/CapsItem.astro';
import MediaCarousel from '../components/MediaCarousel.astro';
import { Content as AboutContent } from '../content/home/about.mdx';

const carouselItems = [
  { name: 'aerial-city.mp4',       src: 'https://picsum.photos/seed/aerial9/800/600',    resolution: '3840×2160', codec: 'MP4',  type: 'video', duration: '0:47',  size: '1.2 GB',  procMs: 820  },
  { name: 'portrait-session.jpg',  src: 'https://picsum.photos/seed/portrait2/800/600',  resolution: '4000×3000', codec: 'JPEG', type: 'photo', duration: '',      size: '18 MB',   procMs: 340  },
  { name: 'product-360.mp4',       src: 'https://picsum.photos/seed/product9/800/600',   resolution: '1920×1080', codec: 'MP4',  type: 'video', duration: '2:14',  size: '340 MB',  procMs: 1240 },
  { name: 'landscape-raw.cr3',     src: 'https://picsum.photos/seed/mountain7/800/600',  resolution: '6720×4480', codec: 'CR3',  type: 'raw',   duration: '',      size: '52 MB',   procMs: 1850 },
  { name: 'interview-b-roll.mov',  src: 'https://picsum.photos/seed/office3/800/600',    resolution: '1920×1080', codec: 'MOV',  type: 'video', duration: '8:32',  size: '4.1 GB',  procMs: 960  },
  { name: 'concert-crowd.jpg',     src: 'https://picsum.photos/seed/concert4/800/600',   resolution: '5472×3648', codec: 'JPEG', type: 'photo', duration: '',      size: '22 MB',   procMs: 280  },
  { name: 'timelapse-stars.mp4',   src: 'https://picsum.photos/seed/stars88/800/600',    resolution: '4096×2160', codec: 'MP4',  type: 'video', duration: '1:03',  size: '890 MB',  procMs: 1100 },
  { name: 'product-flat-lay.png',  src: 'https://picsum.photos/seed/flatlay5/800/600',   resolution: '3000×2000', codec: 'PNG',  type: 'photo', duration: '',      size: '11 MB',   procMs: 410  },
  { name: 'drone-coastline.mp4',   src: 'https://picsum.photos/seed/coast11/800/600',    resolution: '4096×2160', codec: 'MP4',  type: 'video', duration: '3:21',  size: '2.2 GB',  procMs: 740  },
  { name: 'fashion-editorial.jpg', src: 'https://picsum.photos/seed/fashion6/800/600',   resolution: '5000×3333', codec: 'JPEG', type: 'photo', duration: '',      size: '31 MB',   procMs: 390  },
  { name: 'astrophoto-deep.tiff',  src: 'https://picsum.photos/seed/astro22/800/600',    resolution: '7360×4912', codec: 'TIFF', type: 'raw',   duration: '',      size: '140 MB',  procMs: 2100 },
  { name: 'event-highlight.mp4',   src: 'https://picsum.photos/seed/event33/800/600',    resolution: '1920×1080', codec: 'MP4',  type: 'video', duration: '4:55',  size: '1.8 GB',  procMs: 1500 },
];
---

<MainLayout
  title="Thumbrella — fast thumbnails for any media"
  description="Thumbrella generates fast thumbnails for any online media: video, camera photos, documents, 3D models, and more. Open source, free to self-host, with client libraries for most languages."
>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section class="hero" id="hero">
    <div class="container hero__inner">
      <img src="/thumbrella.png" alt="Thumbrella" class="hero__logo" />
      <h1>Fast thumbnails for<br /><span class="hero__any">online</span> media.</h1>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ CAROUSEL -->
  <MediaCarousel items={carouselItems} />

  <!-- ═══════════════════════════════════════════ WHAT IT DOES -->
  <section class="hp-section hp-section--no-border">
    <div class="container">
      <div class="caps-grid">

        <div class="caps-col">
          <h3 class="caps-col__heading">Why Thumbrella</h3>
          <ul class="caps-list">
            <CapsItem icon="⚡" title="High performance">Processing written in Rust. Remote data only downloads what is needed. Render processes are sandboxed for safety and stability.</CapsItem>
            <CapsItem icon="🌍" title="Advanced caching">Cache thumbnails across 300+ worldwide regions. Every response includes standard HTTP cache headers. Re-requesting the same thumbnail is nearly free.</CapsItem>
            <CapsItem icon="⚖️" title="Open source" suffix="— Apache 2">Use it commercially, modify it, redistribute it. No strings attached. Source on GitHub.</CapsItem>
            <CapsItem icon="🖥️" title="Self-host for free">Run Thumbrella on your own hardware with an SQLite cache. No account required, works offline. Single binary — runs standalone or in Docker.</CapsItem>
            <CapsItem icon="📦" title="Client libraries">npm install @thumbrella/client — or pip install thumbrella. Same URL-based interface in both runtimes. <a href="/docs/clients/web-client">Docs →</a></CapsItem>
          </ul>
        </div>

        <div class="caps-col">
          <h3 class="caps-col__heading">Media formats</h3>
          <ul class="caps-list">
            <CapsItem icon="🎬" title="Video" count="14">MP4, MOV, MKV, WebM, AVI, FLV, TS, M4V, 3GP, OGV, RM, ASF, WMV, MPEG. Extracts frames at any timestamp.</CapsItem>
            <CapsItem icon="🖼️" title="Images" count="18">JPEG, PNG, WebP, AVIF, GIF, TIFF, BMP, HEIC, JXL, and more — plus camera RAW: CR2, CR3, NEF, ARW, DNG, RAF, ORF, RW2, and dozens of manufacturer formats.</CapsItem>
            <CapsItem icon="📄" title="Documents" count="3">PDF, DOCX, PPTX — generates a preview image of any page.</CapsItem>
            <CapsItem icon="🧊" title="3D geometry" count="3">OBJ, GLTF, STL — renders an isometric preview of 3D models.</CapsItem>
            <CapsItem icon="✏️" title="Vector graphics" count="3">SVG, EPS, AI — rendered at any resolution without quality loss.</CapsItem>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ DOCS / ABOUT -->
  <section class="hp-section">
    <div class="container hp-prose">
      <AboutContent />
    </div>
  </section>

</MainLayout>

<script>
  import { computePosition, flip, shift, offset, autoUpdate } from '@floating-ui/dom';

  // ── CapsItem popovers ──────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.caps-item[aria-controls]').forEach((item) => {
    const id = item.getAttribute('aria-controls')!;
    const popover = document.getElementById(id) as HTMLElement | null;
    if (!popover) return;

    let cleanup: (() => void) | null = null;

    const reposition = () =>
      computePosition(item, popover, {
        strategy: 'fixed',
        placement: 'top',
        middleware: [offset(8), flip(), shift({ padding: 8 })],
      }).then(({ x, y }) => {
        Object.assign(popover.style, { left: `${x}px`, top: `${y}px` });
      });

    item.addEventListener('click', (e) => {
      if ((e.target as Element).closest('.info-popover a')) return;
      if (popover.matches(':popover-open')) {
        popover.hidePopover();
      } else {
        popover.showPopover();
        cleanup = autoUpdate(item, popover, reposition);
      }
    });

    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); item.click(); }
    });

    popover.addEventListener('toggle', (e) => {
      const { newState } = e as ToggleEvent;
      item.setAttribute('aria-expanded', newState === 'open' ? 'true' : 'false');
      if (newState === 'closed') { cleanup?.(); cleanup = null; }
    });
  });



</script>
