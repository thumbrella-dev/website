---
import MainLayout from '../layouts/MainLayout.astro';
import ProsePopover from '../components/ProsePopover.astro';
import FormatChip from '../components/FormatChip.astro';
import MediaCarousel from '../components/MediaCarousel.astro';
import { Content as AboutContent } from '../content/home/about.mdx';
import { fetchDemoGallery, shuffleGallery } from '../lib/demo-gallery';
import ClientTabs from '../components/ClientTabs.astro';
import HostingTabs from '../components/HostingTabs.astro';
import NewsSection from '../components/NewsSection.astro';

// Seed with a few items so the carousel has content before the full index loads
const SEED_FILES = [
  'harbor-trucks.mp4',
  'space-colony.jpg',
  'dudu-intro.mp3',
];

let carouselItems = await fetchDemoGallery();
if (carouselItems.length > 0) {
  carouselItems = shuffleGallery(carouselItems);
} else {
  // Fallback: fetch just the seed items if the full index failed
  carouselItems = await fetchDemoGallery(SEED_FILES);
}
---

<MainLayout
  title="Thumbrella is the open source server for online thumbnails"
  description="Serve fast, cached thumbnails from over 100 formats: photographs, videos, documents, even 3D models. Feed it your media libraries and get reliable thumbnail back. One command runs it locally or in Docker. Our Thumbrella Cloud is efficient enough to offer a genuinely useful free tier. Start with client the packages for languages you already use. Docs and examples get you streaming thumbnails immediately.">

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section class="hero" id="hero">
    <div class="container hero__inner">
      <img src="/thumbrella.png" alt="Thumbrella" class="hero__logo" />
      <h1>Fast thumbnails for<br /><span class="hero__any">online</span> media.</h1>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ CAROUSEL -->
  <MediaCarousel items={carouselItems} />

  <!-- ═══════════════════════════════════════════ WHAT IT DOES -->
  <section class="hp-section hp-section--no-border">
    <div class="container">
      <h2 class="section-heading">About</h2>
      <div class="caps-panel">

        <p class="caps-prose">
          Thumbrella is the
          <ProsePopover> <span slot="trigger">open source</span>
            Apache&nbsp;2 license for the server and all client libraries.<br>
            One of the easiest licenses to integrate into any project.
          </ProsePopover>
          server for online thumbnails. 
          
        </p>
        <p class="caps-prose">
          
          Serve
          <ProsePopover> <span slot="trigger">fast, cached</span>
            Processing written in Rust. Cache thumbnails across 300+ worldwide regions. Every response includes standard HTTP cache headers. Re-requesting the same thumbnail is nearly free.
          </ProsePopover>
          thumbnails from over 100 formats —
          <ProsePopover> <span slot="trigger">photographs, video, documents, even 3D models</span>
            Camera RAW, legacy video codecs, old document formats, 3D geometry, vector graphics, and more.
          </ProsePopover>.

        </p>
        <p class="caps-prose">

          Many
          <ProsePopover> <span slot="trigger">client libraries</span>
            <code>npm install @thumbrella/client</code>, <code>pip install thumbrella</code>, Go, Rust, React. Same URL-based interface everywhere. <a href="/docs/client">Docs →</a>
          </ProsePopover>
          provide easy
          <ProsePopover> <span slot="trigger">streaming and batching</span>
            Stream individual thumbnails or batch-process entire directories. Built-in concurrency control and automatic retry.
          </ProsePopover>
          out of the box.

        </p>
        <p class="caps-prose">
          <ProsePopover> <span slot="trigger">Self-host</span>
            Run your own production server with one simple command. Or work with docker compose and other container tools.
          </ProsePopover>
          or use the
          <ProsePopover> <span slot="trigger">Thumbrella Cloud</span>
            One click sign in for a new account and get going for free.
          </ProsePopover>
          for free.
        </p>

        <div class="caps-formats">
          <FormatChip icon="🎬" title="Video" count="12">Video thumbnails are efficiently extracted from encoded keyframes early in the video.<br>MP4, MOV, MKV, AVI, FLV, TS, M4V, 3GP, OGV, WMV, MPEG...</FormatChip>
          <FormatChip icon="🖼️" title="Images" count="16">Image formats often contain simple colors pixel data for a variety of digital uses.<br>JPEG, PNG, WEBP, AVIF, GIF, TIFF, BMP, HEIC, JP2, JXL, ICO, PSD, PPM, TGA...</FormatChip>
          <FormatChip icon="📷" title="Photographs" count="17">Camera and film formats are often heavy and high definition frame captures and often need color processing.<br>RAW, DNG, EXR, HDR, CR2, NEF, ARW, ORF, RW2, PEF, SRW, RAF, 3FR, MEF...</FormatChip>
          <FormatChip icon="📄" title="Documents" count="7">Documents are usually multi-page collections
            of styled text and media.<br>PDF, DOCX, PPTX, ODT, XLSX, ODS, ODP.</FormatChip>
          <FormatChip icon="🧊" title="3D geometry" count="37">Three dimensional models and scenes that can contain triangles, shaders, and textures.<br>OBJ, GLTF, GLB, STL, FBX, USDZ, IGES, DAE, PLY, 3DS, VRML...</FormatChip>
          <FormatChip icon="✏️" title="Vector graphics" count="1">Graphical descriptions of shapes and materials.<br>SVG<br>(more formats coming soon).</FormatChip>
        </div>

      </div>
    </div>
  </section>


  <NewsSection />

  <ClientTabs />

  <HostingTabs />


  <!-- ══════════════════════════════════════════ DOCS / ABOUT -->
  <section class="hp-section">
    <div class="container hp-prose">
      <AboutContent />
    </div>
  </section>

</MainLayout>

<script>
  import { computePosition, flip, shift, offset, autoUpdate } from '@floating-ui/dom';

  // ── CapsItem, ProsePopover + FormatChip popovers ──────────────────────────
  document.querySelectorAll<HTMLElement>(
    '.prose-popover[aria-controls], .fmt-chip[aria-controls]'
  ).forEach((item) => {
    const id = item.getAttribute('aria-controls')!;
    const popover = document.getElementById(id) as HTMLElement | null;
    if (!popover) return;

    let cleanup: (() => void) | null = null;

    const reposition = () =>
      computePosition(item, popover, {
        strategy: 'fixed',
        placement: 'top',
        middleware: [offset(8), flip(), shift({ padding: 8 })],
      }).then(({ x, y }) => {
        Object.assign(popover.style, { left: `${x}px`, top: `${y}px` });
      });

    item.addEventListener('click', (e) => {
      if ((e.target as Element).closest('.info-popover a')) return;
      if (popover.matches(':popover-open')) {
        popover.hidePopover();
      } else {
        popover.showPopover();
        cleanup = autoUpdate(item, popover, reposition);
      }
    });

    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); item.click(); }
    });

    popover.addEventListener('toggle', (e) => {
      const { newState } = e as ToggleEvent;
      item.setAttribute('aria-expanded', newState === 'open' ? 'true' : 'false');
      if (newState === 'closed') { cleanup?.(); cleanup = null; }
    });
  });



</script>
