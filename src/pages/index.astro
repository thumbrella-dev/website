---
import MainLayout from '../layouts/MainLayout.astro';
import ProsePopover from '../components/ProsePopover.astro';
import FormatChip from '../components/FormatChip.astro';
import MediaCarousel from '../components/MediaCarousel.astro';
import { Content as AboutContent } from '../content/home/about.mdx';
import { fetchDemoGallery, shuffleGallery } from '../lib/demo-gallery';
import ClientTabs from '../components/ClientTabs.astro';
import HostingTabs from '../components/HostingTabs.astro';
import NewsSection from '../components/NewsSection.astro';

// Seed with a few items so the carousel has content before the full index loads
const SEED_FILES = [
  'harbor-trucks.mp4',
  'space-colony.jpg',
  'dudu-intro.mp3',
];

let carouselItems = await fetchDemoGallery();
if (carouselItems.length > 0) {
  carouselItems = shuffleGallery(carouselItems);
} else {
  // Fallback: fetch just the seed items if the full index failed
  carouselItems = await fetchDemoGallery(SEED_FILES);
}
---

<MainLayout
  title="Thumbrella is the open source server for online thumbnails"
  description="Serve fast, cached thumbnails from over 100 formats: photographs, videos, documents, even 3D models. Feed it your media libraries and get reliable thumbnail back.">

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="container hero__inner">
      <img src="/thumbrella.png" alt="Thumbrella" class="hero__logo" />
      <h1>Fast thumbnails for<br /><span class="hero__any">online</span> media.</h1>
    </div>
  </section>

  <!-- CAROUSEL -->
  <MediaCarousel items={carouselItems} />

  <!-- WHAT IT DOES -->
  <section class="hp-section hp-section--no-border">
    <div class="container">
      <h2 class="section-heading">About</h2>
      <div class="caps-panel">

        <p class="caps-prose">
          Thumbrella is the
          <ProsePopover> <span slot="trigger">open source</span>
            Apache&nbsp;2 license for the server and all client libraries.<br>
            One of the simplest licenses to integrate into any project.
          </ProsePopover>
          server for online thumbnails. 
          
        </p>
        <p class="caps-prose">
          Serve
          <ProsePopover> <span slot="trigger">fast, cached</span>
            Server written in Rust and deployed to the edge in over 300 regions.<br>
            Full integration with http caching headers and range requests 
            for excellent performance.
          </ProsePopover>
          thumbnails from over
          <ProsePopover> <span slot="trigger">100 formats</span>
            Handles megapixel imagery with complicated pixel formats and codecs.<br>
            Efficiently work through massive video files.<br>
            Render quality images from vector artwork, 3d models, and documents.<br>
            Quickly extract embedded thumbnails and cover art from other formats.
          </ProsePopover>:
          photographs, videos, documents, even 3D models.

        </p>
        <p class="caps-prose">
          <ProsePopover> <span slot="trigger">One command</span>
            Run from most operating systems, `<code>npx @thumbrella/server serve</code>`
            and be running in seconds.<br>
            Or work with Docker with `<code>docker run -it -p 3114:3114 thumbrella/server</code>`.<br>
          </ProsePopover>
          runs it locally or in Docker. Our
          <ProsePopover> <span slot="trigger">Thumbrella Cloud</span>
            Register with an existing developer account in <a href="/account">two clicks</a>, no payment info.<br>
            Set your token and get full access to all features.
          </ProsePopover>
          is efficient enough to offer a genuinely useful free tier.
        </p>
        <p class="caps-prose">
          Start with
          <ProsePopover> <span slot="trigger">client libraries</span>
            packages already available for Typescript, Python, and Rust.<br>
            High level web components for Astro and React.<br>
            Set a connection string, `<code>Client().batch(urls)</code>`, and done.<br>
            <a href="/docs/client">Docs →</a>
          </ProsePopover>
          for languages you already use. Docs and examples get you
          <ProsePopover> <span slot="trigger">streaming thumbnails</span>
            Stream individual thumbnails or batch-process entire directories.<br>
            Resilient clients provide placeholders even when the server is unreachable.
          </ProsePopover>
          immediately.
        </p>

        <div class="caps-formats">
          <FormatChip icon="🎬" title="Video" count="14">Video thumbnails are efficiently extracted from encoded keyframes in the video.<br>MP4, MOV, MKV, AVI, FLV, TS, M4V, 3GP, OGV, WMV, MPEG...</FormatChip>
          <FormatChip icon="🖼️" title="Images" count="19">Common image formats designed to be lightweight for a variety of digital uses. From tiny pixel art to panoramic megapixels.<br>JPEG, PNG, WEBP, AVIF, GIF, TIFF, BMP, HEIC, JP2, JXL, ICO, PSD, PPM, TGA...</FormatChip>
          <FormatChip icon="📷" title="Photographs" count="27">Camera and film formats are often heavy and high definition frame captures, multichannel imagery that requires color processing.<br>RAW, DNG, EXR, HDR, CR2, NEF, ARW, ORF, RW2, PEF, SRW, RAF, 3FR, MEF...</FormatChip>
          <FormatChip icon="🧊" title="3D geometry" count="26">Three dimensional models and scenes that can contain triangles, shaders, and textures.<br>OBJ, GLTF, GLB, STL, FBX, USDZ, IGES, DAE, PLY, 3DS, VRML...</FormatChip>
          <FormatChip icon="📄" title="Documents" count="6">Documents are usually multi-page collections of styled text and media.<br>DOCX, PPTX, ODT, XLSX, ODS, ODP, PDF (soon).</FormatChip>
          <FormatChip icon="📦" title="And more" count="10">Vector graphics are rendered in high quality. Even audio formats commonly provide cover art to view. And more on the way.<br>SVG, MP3, FLAC, OGG, M4A, AAC...</FormatChip>
        </div>

      </div>
    </div>
  </section>


  <NewsSection />

  <ClientTabs />

  <HostingTabs />


  <!-- DOCS / ABOUT -->
  <section class="hp-section">
    <div class="container hp-prose">
      <AboutContent />
    </div>
  </section>

</MainLayout>

<script>
  import { computePosition, flip, shift, offset, autoUpdate } from '@floating-ui/dom';

  document.querySelectorAll<HTMLElement>(
    '.prose-popover[aria-controls], .fmt-chip[aria-controls]'
  ).forEach((item) => {
    const id = item.getAttribute('aria-controls')!;
    const popover = document.getElementById(id) as HTMLElement | null;
    if (!popover) return;

    let cleanup: (() => void) | null = null;

    const reposition = () =>
      computePosition(item, popover, {
        strategy: 'fixed',
        placement: 'top',
        middleware: [offset(8), flip(), shift({ padding: 8 })],
      }).then(({ x, y }) => {
        Object.assign(popover.style, { left: `${x}px`, top: `${y}px` });
      });

    item.addEventListener('click', (e) => {
      if ((e.target as Element).closest('.info-popover a')) return;
      if (popover.matches(':popover-open')) {
        popover.hidePopover();
      } else {
        popover.showPopover();
        cleanup = autoUpdate(item, popover, reposition);
      }
    });

    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); item.click(); }
    });

    popover.addEventListener('toggle', (e) => {
      const { newState } = e as ToggleEvent;
      item.setAttribute('aria-expanded', newState === 'open' ? 'true' : 'false');
      if (newState === 'closed') { cleanup?.(); cleanup = null; }
    });
  });

</script>
