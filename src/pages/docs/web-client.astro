---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/Section.astro';
---

<MainLayout
  title="Web client docs"
  description="Getting started notes for the Thumbrella web client."
>
  <Section
    eyebrow="web client docs"
    title="Start from the package boundary"
    lede="The web client docs should answer installation, initialization, and the basic request flow with as little ceremony as possible."
  >
    <p>Expected baseline for this section:</p>
    <ul>
      <li>Installation command and supported runtime versions.</li>
      <li>Minimal client setup with authentication.</li>
      <li>Small examples for listing libraries, fetching metadata, and streaming assets.</li>
    </ul>
    <pre><code>npm install @thumbrella/web-client</code></pre>
  </Section>
</MainLayout>