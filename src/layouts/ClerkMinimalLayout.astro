---
import { Show, UserButton, SignInButton, SignUpButton, SignOutButton } from '@clerk/astro/components';

interface Props {
  title?: string;
}

const { title = 'Clerk + Astro Minimal' } = Astro.props;

const currentUser =
  typeof Astro.locals.currentUser === 'function' ? await Astro.locals.currentUser() : null;
const primaryEmail = currentUser?.primaryEmailAddress?.emailAddress ?? 'Unavailable';
const firstName = currentUser?.firstName ?? 'Unknown';
const userId = currentUser?.id ?? 'Unavailable';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <header class="bar">
      <Show when="signed-out">
        <SignInButton mode="modal" />
        <SignUpButton mode="modal" />
      </Show>
      <Show when="signed-in">
        <button type="button" id="open-manage-account" class="small-btn">Manage account</button>
        <SignOutButton redirectUrl="/clerk-minimal" asChild>
          <button type="button" class="small-btn">Log out</button>
        </SignOutButton>
        <UserButton>
          <UserButton.UserProfilePage label="Usage" url="usage">
            <h2>Usage</h2>
            <p>This is a custom profile page injected by the Astro app.</p>
            <p>Example metrics: 2.7 GB cache, 2,140 requests, 0 failed jobs today.</p>
            <p><strong>Signed-in email:</strong> {primaryEmail}</p>
            <p><strong>First name:</strong> {firstName}</p>
          </UserButton.UserProfilePage>

          <UserButton.UserProfilePage label="Tokens" url="tokens">
            <h2>Tokens</h2>
            <p>Prototype token controls can be linked here.</p>
            <p>Example: Default key, Rotate key, Restrict by domain.</p>
            <p><strong>Signed-in email:</strong> {primaryEmail}</p>
            <p><strong>User ID:</strong> {userId}</p>
          </UserButton.UserProfilePage>
        </UserButton>
      </Show>
    </header>
    <main>
      <slot />
    </main>

    <script is:inline>
      const manageAccount = document.getElementById('open-manage-account');
      if (manageAccount) {
        manageAccount.addEventListener('click', () => {
          const userButtonMap = window.__astro_clerk_component_props?.get('user-button');
          const firstConfig = userButtonMap ? Array.from(userButtonMap.values())[0] : undefined;
          window.Clerk?.openUserProfile(firstConfig?.userProfileProps);
        });
      }
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    font-family: ui-sans-serif, system-ui, sans-serif;
    background: #12151a;
    color: #f2f5f8;
  }

  .bar {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .small-btn {
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.06);
    color: #f2f5f8;
    border-radius: 8px;
    padding: 0.45rem 0.7rem;
    cursor: pointer;
  }

  .small-btn:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  main {
    padding: 1.5rem 1rem;
  }
</style>