---
export interface Props {
  title: string;
  price: string;
  href: string;
  featured?: boolean;
}

const { title, price, href, featured = false } = Astro.props;
---

<article class:list={['pricing-card', { featured }]}>
  <div class="card-header">
    <h3 class="title">{title}</h3>
    <span class="price">{price}</span>
    <a href={href} class="signup-btn">Sign Up</a>
  </div>
  <div class="card-body">
    <slot />
  </div>
</article>

<style>
  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(200, 149, 78, 0.25);
    border-radius: 12px;
    background:
      linear-gradient(160deg, rgba(200, 149, 78, 0.08) 0%, rgba(200, 149, 78, 0.02) 40%, transparent 70%),
      linear-gradient(180deg, #252018 0%, #1f1a14 100%);
    overflow: hidden;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .pricing-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #c08840, #dba95e, #8a6d3b);
    opacity: 0.7;
  }

  .pricing-card:hover {
    border-color: rgba(200, 149, 78, 0.5);
    box-shadow: 0 4px 24px rgba(200, 149, 78, 0.08);
  }

  .pricing-card.featured {
    border-color: rgba(200, 149, 78, 0.45);
    background:
      linear-gradient(160deg, rgba(200, 149, 78, 0.12) 0%, rgba(200, 149, 78, 0.03) 40%, transparent 70%),
      linear-gradient(180deg, #2a2318 0%, #1f1a14 100%);
  }

  .pricing-card.featured::before {
    background: linear-gradient(90deg, #dba95e, #f0c878, #c08840);
    opacity: 1;
    height: 4px;
  }

  .card-header {
    padding: 1.75rem 1.75rem 0 1.75rem;
  }

  .title {
    font-size: var(--sl-text-h3);
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.25rem 0;
    line-height: 1.3;
  }

  .price {
    display: block;
    font-size: var(--sl-text-lg);
    color: var(--sl-color-accent-high);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .signup-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.6rem 1.5rem;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: #f0e8d8;
    background: linear-gradient(135deg, #7c5cbf 0%, #5e3fa0 100%);
    border: 1px solid rgba(124, 92, 191, 0.35);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .signup-btn:hover {
    background: linear-gradient(135deg, #9b7bd4 0%, #7c5cbf 100%);
    border-color: rgba(169, 140, 214, 0.55);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(124, 92, 191, 0.3);
    color: #f0e8d8;
    text-decoration: none;
  }

  .signup-btn:active {
    transform: translateY(0);
  }

  .card-body {
    padding: 1.25rem 1.75rem 1.75rem 1.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    line-height: 1.7;
  }

  .card-body :global(strong) {
    color: var(--sl-color-gray-1);
    font-weight: 600;
  }

  .card-body :global(ul) {
    padding-left: 1.25rem;
    margin: 0.25rem 0 0.75rem 0;
  }

  .card-body :global(li) {
    margin-bottom: 0.15rem;
  }

  .card-body :global(a) {
    color: var(--sl-color-accent-high);
  }

  .card-body > :global(*:first-child) {
    margin-top: 0;
  }

  .card-body > :global(*:last-child) {
    margin-bottom: 0;
  }
</style>
