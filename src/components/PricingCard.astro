---
export interface Props {
  title: string;
  price: string;
  period?: string;
}

const { title, price, period } = Astro.props;
---

<article class:list={['pricing-card']}>
  <div class="card-header">
    <h3 class="title">{title}</h3>
    <span class="price"><b>{price}</b>{period}</span>
  </div>
  <div class="card-body">
    <slot />
  </div>
</article>

<style>
  .pricing-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(200, 149, 78, 0.5);
    border-top-style: 3px solid rgba(200, 149, 78, 0.5);
    border-radius: 12px;
    background:
      linear-gradient(160deg, rgba(200, 149, 78, 0.08) 0%, rgba(200, 149, 78, 0.02) 40%, transparent 70%),
      linear-gradient(180deg, #252018 0%, #1f1a14 100%);
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  b {
    font-size: 200%;
    font-weight: normal;
  }

  .pricing-card:hover {
    border-color: rgba(223, 171, 97, 0.648);
    box-shadow: 0 4px 24px rgba(200, 149, 78, 0.08);
  }

  .card-header {
    padding: 1.75rem 1.75rem 0 1.75rem;
  }

  .title {
    font-size: var(--sl-text-h3);
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.25rem 0;
    line-height: 1.3;
  }

  .price {
    display: block;
    font-size: var(--sl-text-lg);
    color: var(--sl-color-accent-high);
    font-weight: 600;
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 0.5rem 1.75rem 1.75rem 1.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    line-height: 1.65;
  }

  .card-body > :first-child {
    margin-top: 0.25rem;
  }
    line-height: 1.7;
  }


  .card-body table {
    margin-top: 1rem;
  }

  .card-body :global(strong) {
    color: var(--sl-color-gray-1);
    font-weight: 600;
  }
</style>
