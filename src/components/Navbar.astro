---
import { SignInButton, UserButton, Show } from '@clerk/astro/components';
import { env } from 'cloudflare:workers';

const userIconSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';

const links = [
  {
    href: '/docs',
    activePrefix: '/docs',
    text: 'Docs',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>',
  },
  {
    href: '/pricing',
    activePrefix: '/pricing',
    text: 'Pricing',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r="1" fill="currentColor" stroke="none"/></svg>',
  },
  {
    href: 'https://github.com/thumbrella/thumbrella',
    text: 'GitHub',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  },
] as const;

const currentPath = Astro.url.pathname;
const currentUser =
  typeof Astro.locals.currentUser === 'function' ? await Astro.locals.currentUser() : null;
const primaryEmail = currentUser?.primaryEmailAddress?.emailAddress ?? 'account';
const clerkUserId = currentUser?.id;

const adminWorker = env.ADMIN_WORKER;

type DashboardTab = { id: string; label: string; url: string; html: string };
let dashboardTabs: DashboardTab[] = [];

const SIGNOUT_BTN =
  '<button type="button" class="tbr-btn tbr-btn-xs tbr-btn-primary" style="text-transform:none;letter-spacing:0;margin-left:auto" data-manage-account-sign-out>Sign out</button>';
const processTabHtml = (tab: DashboardTab) => tab.html.replace('{{SIGNOUT}}', SIGNOUT_BTN);

if (clerkUserId && adminWorker) {
  try {
    const url = new URL(
      `/api/dashboard?clerkUserId=${encodeURIComponent(clerkUserId)}`,
      'http://admin.internal'
    );
    const resp = await adminWorker.fetch(url.toString());
    if (resp.ok) {
      const data = await resp.json<{ tabs?: DashboardTab[] }>();
      dashboardTabs = Array.isArray(data?.tabs) ? data.tabs : [];
    } else {
      const text = await resp.text();
      console.log('[Navbar] error body:', text);
    }
  } catch (err) {
    console.log('[Navbar] fetch threw:', err);
  }
}
---

<header class="navbar">
  <div class="container navbar__inner">
    <a class="brand" href="/">
      <img src="/thumbrella.png" alt="Thumbrella" class="brand__logo" id="nav-logo" data-logo-hidden />
      thumbrella.dev
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {links.map((link) => (
          <li>
            <a class:list={['nav-link', ('activePrefix' in link ? currentPath.startsWith(link.activePrefix) : currentPath === link.href) && 'is-active']} href={link.href}>
              <Fragment set:html={link.icon} />
              {link.text}
            </a>
          </li>
        ))}
        <li class="nav-auth-group">
          <Show when="signed-out">
            <SignInButton mode="modal" asChild>
              <button type="button" id="nav-sign-in" class="nav-auth-btn">
                <Fragment set:html={userIconSvg} />
                Sign in
              </button>
            </SignInButton>
          </Show>
          <Show when="signed-in">
            <button type="button" id="open-manage-account-nav" class="nav-auth-btn">
              <Fragment set:html={userIconSvg} />
              Manage Account
            </button>
          </Show>
        </li>
        <li class="nav-auth-group">
          <UserButton>
            {dashboardTabs.length > 0 ? dashboardTabs.map(tab => (
              <UserButton.UserProfilePage label={tab.label} url={tab.url}>
                <div class="nav-admin-dashboard-shell">
                  <div class="nav-admin-dashboard" set:html={processTabHtml(tab)} />
                </div>
              </UserButton.UserProfilePage>
            )) : (
              <UserButton.UserProfilePage label="Thumbrella" url="manage-account">
                <div class="nav-admin-dashboard-shell">
                  <button type="button" class="nav-dashboard-sign-out" data-manage-account-sign-out>
                    Sign out
                  </button>
                  <p>Dashboard data is currently unavailable.</p>
                </div>
              </UserButton.UserProfilePage>
            )}
          </UserButton>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  // ── Nav logo: fade in after scrolling past hero ───────────────────────────
  window.addEventListener('DOMContentLoaded', () => {
    const navLogo = document.getElementById('nav-logo');
    const hero = document.getElementById('hero');

    if (!navLogo) return;

    // Logo starts invisible (via [data-logo-hidden] CSS). Decide how to proceed:
    navLogo.style.transition = 'opacity 0.35s ease';

    if (hero) {
      // Homepage: tie visibility to hero leaving viewport
      const observer = new IntersectionObserver(
        ([entry]) => {
          navLogo.style.opacity = entry.isIntersecting ? '0' : '1';
        },
        { threshold: 0.1 }
      );
      observer.observe(hero);
    } else {
      // Any other page: show immediately (small fade-in feels intentional)
      requestAnimationFrame(() => { navLogo.style.opacity = '1'; });
    }
  });

  const manageAccount = document.getElementById('open-manage-account-nav');
  let previousUserId = null;

  const getUserButtonConfig = () => {
    const userButtonMap = window.__astro_clerk_component_props?.get('user-button');
    return userButtonMap ? Array.from(userButtonMap.values())[0] : undefined;
  };

  const openManageAccount = () => {
    if (!window.Clerk?.user) {
      return;
    }

    const userButtonConfig = getUserButtonConfig();
    window.Clerk.openUserProfile({
      ...(userButtonConfig?.userProfileProps ?? {}),
      __experimental_startPath: '/manage-account',
    });
  };

  // Manual button event listeners
  if (manageAccount) {
    manageAccount.addEventListener('click', () => {
      void openManageAccount();
    });
  }

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) {
      return;
    }

    if (target.closest('[data-manage-account-sign-out]')) {
      void window.Clerk?.signOut({ redirectUrl: '/' });
    }
  });

  // Dashboard script re-activation shim.
  // Clerk renders UserButton.UserProfilePage content via innerHTML, which does not
  // execute <script> tags. This shim watches for [data-tbr-script] elements to appear
  // and copies their content to new <script> tags that the browser WILL execute.
  (function () {
    function activateDashboardScripts() {
      document.querySelectorAll('[data-tbr-script]').forEach(function (s) {
        if (s.dataset.tbrActivated) return;
        s.dataset.tbrActivated = '1';
        var n = document.createElement('script');
        n.textContent = s.textContent;
        document.head.appendChild(n);
      });
    }
    activateDashboardScripts();
    var obs = new MutationObserver(activateDashboardScripts);
    obs.observe(document.body, { childList: true, subtree: true });
  })();

  // Wait for Clerk to load, then set up listener
  const waitForClerk = window.setInterval(() => {
    if (!window.Clerk) return;

    window.clearInterval(waitForClerk);

    // Seed previousUserId from current state so a page load/refresh while
    // already signed in does NOT look like a fresh sign-in transition.
    // NOTE: user may not be populated yet even when Clerk SDK is ready —
    // the session loads asynchronously and arrives via addListener below.
    previousUserId = window.Clerk?.user?.id ?? null;

    // Fast path: session already available (cached/warm load)
    if (window.location.pathname === '/account' && window.Clerk.user) {
      openManageAccount();
    }

    // Listen for auth state changes
    window.Clerk.addListener(() => {
      const currentUserId = window.Clerk?.user?.id;
      const wasSignedOut = previousUserId === null;
      const isNowSignedIn = currentUserId !== null && currentUserId !== undefined;

      if (wasSignedOut && isNowSignedIn) {
        const createdAt = window.Clerk?.user?.createdAt;
        const isNewSignUp = createdAt && (Date.now() - new Date(createdAt).getTime()) < 30000;
        // Auto-open on /account direct navigation (session just loaded),
        // or on a fresh sign-up anywhere on the site.
        if (window.location.pathname === '/account' || isNewSignUp) {
          openManageAccount();
        }
      }

      previousUserId = currentUserId;
    });
  }, 100);

  // ── /account URL sync ─────────────────────────────────────────────────────
  // Push /account when the Clerk modal opens; restore / when it closes.
  // Also handles the browser back button while the modal is open.
  (function () {
    var modalOpen = false;

    var urlObs = new MutationObserver(function () {
      var nowOpen = !!document.querySelector('.cl-modalBackdrop');
      if (nowOpen === modalOpen) return;
      modalOpen = nowOpen;
      if (nowOpen) {
        if (window.location.pathname !== '/account') {
          history.pushState({ clerkModal: true }, '', '/account');
        }
      } else {
        if (window.location.pathname === '/account') {
          history.replaceState({}, '', '/');
        }
      }
    });
    urlObs.observe(document.body, { childList: true, subtree: true });

    // Back button while modal is open → close the modal, stay on /
    window.addEventListener('popstate', function (e) {
      if (modalOpen) {
        document.dispatchEvent(
          new KeyboardEvent('keydown', { key: 'Escape', bubbles: true, cancelable: true })
        );
      }
    });
  })();
</script>

<style>
  .nav-auth-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    border-radius: 999px;
    padding: 0.45rem 0.7rem;
    cursor: pointer;
    font: inherit;
  }

  .nav-auth-btn:hover {
    color: #fff;
    background: rgba(215, 155, 91, 0.16);
  }

  .nav-auth-btn--email {
    max-width: 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.nav-admin-dashboard-shell) {
    display: grid;
    gap: 1rem;
  }

  :global(.nav-dashboard-sign-out) {
    justify-self: start;
    border: 1px solid rgba(248, 113, 113, 0.35);
    background: rgba(248, 113, 113, 0.1);
    color: #f87171;
    border-radius: 6px;
    padding: 0.45rem 1rem;
    cursor: pointer;
    font: 500 0.825rem inherit;
    letter-spacing: 0.01em;
  }

  :global(.nav-dashboard-sign-out:hover) {
    background: rgba(248, 113, 113, 0.18);
    border-color: rgba(248, 113, 113, 0.55);
  }

  :global([data-clerk-id^='clerk-user-button']) {
    display: none;
  }
</style>