---
const userIconSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';

const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY ?? '';

const links = [
  {
    href: '/docs',
    activePrefix: '/docs',
    text: 'Docs',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>',
  },
  {
    href: '/docs/pricing',
    activePrefix: '/docs/pricing',
    text: 'Pricing',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r="1" fill="currentColor" stroke="none"/></svg>',
  },
  {
    href: 'https://github.com/thumbrella-dev/thumbrella',
    text: 'GitHub',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  },
] as const;

const currentPath = Astro.url.pathname;
---

<header class="navbar">
  <div class="container navbar__inner">
    <a class="brand" href="/">
      <img src="/navbar.png" alt="Thumbrella" class="brand__logo" id="nav-logo" data-logo-hidden />
      &nbsp;thumbrella.dev&nbsp;
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {links.map((link) => (
          <li>
            <a class:list={['nav-link', ('activePrefix' in link ? currentPath.startsWith(link.activePrefix) : currentPath === link.href) && 'is-active']} href={link.href}>
              <Fragment set:html={link.icon} />
              &nbsp;{link.text}&nbsp;
            </a>
          </li>
        ))}
        <li class="nav-auth-group">
          <button type="button" id="nav-account-btn" class="nav-auth-btn" data-clerk-key={clerkPublishableKey}>
            <Fragment set:html={userIconSvg} />
            Account
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  //  Nav logo: fade in after scrolling past hero
  window.addEventListener('DOMContentLoaded', () => {
    const navLogo = document.getElementById('nav-logo');
    const hero = document.getElementById('hero');

    if (!navLogo) return;

    // Logo starts invisible (via [data-logo-hidden] CSS). Decide how to proceed:
    navLogo.style.transition = 'opacity 0.35s ease';

    if (hero) {
      // Homepage: tie visibility to hero leaving viewport
      const observer = new IntersectionObserver(
        ([entry]) => {
          navLogo.style.opacity = entry.isIntersecting ? '0' : '1';
        },
        { threshold: 0.1 }
      );
      observer.observe(hero);
    } else {
      // Any other page: show immediately (small fade-in feels intentional)
      requestAnimationFrame(() => { navLogo.style.opacity = '1'; });
    }
  });

  // ---- Clerk integration (vanilla JS, lazy-loaded on click) ----
  (function () {
    var accountBtn = document.getElementById('nav-account-btn');
    if (!accountBtn) return;

    var PUBLISHABLE_KEY = accountBtn.getAttribute('data-clerk-key') || '';

    // Derive the Frontend API hostname from the publishable key.
    // The key is base64url-encoded "<frontend-api-hostname>$".  We decode
    // it to build the correct script URL instead of hard-coding a CDN.
    var FRONTEND_API = '';
    try {
      var raw = PUBLISHABLE_KEY.replace(/^pk_(test|live)_/, '');
      var b64 = raw.replace(/-/g, '+').replace(/_/g, '/');
      while (b64.length % 4) b64 += '=';
      var hostWithDollar = atob(b64);
      FRONTEND_API = hostWithDollar.replace(/\$$/, '');
    } catch (e) { /* fall back to empty; loadClerk will fail gracefully */ }
    var CK_SCRIPT = FRONTEND_API
      ? 'https://' + FRONTEND_API + '/npm/@clerk/clerk-js@5/dist/clerk.browser.js'
      : '';

    var clerkReady = false;      // script loaded AND Clerk.load() has resolved
    var clerkLoading = false;    // script in-flight or Clerk.load() in-flight
    var pendingCallbacks = [];   // queue while Clerk is loading/initialising
    var btnOriginalHtml = '';    // saved button content for load/restore
    var clerkPushed = false;     // did we pushState /account?

    function btnLoading(on) {
      if (on) {
        if (!btnOriginalHtml) btnOriginalHtml = accountBtn.innerHTML;
        accountBtn.innerHTML = '<span class="nav-spin"></span> Loading\u2026';
        accountBtn.disabled = true;
      } else {
        if (btnOriginalHtml) accountBtn.innerHTML = btnOriginalHtml;
        accountBtn.disabled = false;
      }
    }

    function clerkPushAccountUrl() {
      if (clerkPushed || window.location.pathname === '/account') return;
      clerkPushed = true;
      history.pushState({}, '', '/account');
    }

    function clerkRestoreUrl() {
      if (window.location.pathname !== '/account') return;
      if (clerkPushed) {
        // We pushed /account; pop it.
        clerkPushed = false;
        history.back();
      } else {
        // We arrived at /account directly; replace with /.
        history.replaceState({}, '', '/');
      }
    }

    function whenClerkReady(cb) {
      if (clerkReady) { cb(); return; }
      pendingCallbacks.push(cb);
      if (!clerkLoading) initClerk();
    }

    function initClerk() {
      if (!CK_SCRIPT) {
        flushCallbacks(new Error('Cannot derive Clerk script URL'));
        return;
      }
      clerkLoading = true;
      btnLoading(true);

      var script = document.createElement('script');
      script.async = true;
      script.setAttribute('data-clerk-publishable-key', PUBLISHABLE_KEY);
      script.src = CK_SCRIPT;
      script.onload = function () {
        // Clerk script is on the page, but components aren't ready yet.
        // Call Clerk.load() to hydrate. On subsequent calls load() is a no-op.
        window.Clerk.load({
          appearance: {
            variables: {
              colorBackground: '#212126',
              colorNeutral: 'white',
              colorPrimary: '#ffffff',
              colorPrimaryForeground: 'black',
              colorForeground: 'white',
              colorInputForeground: 'white',
              colorInput: '#26262B'
            },
            elements: {
              providerIcon__apple: { filter: 'invert(1)' },
              providerIcon__github: { filter: 'invert(1)' }
            }
          }
        })
          .then(function () {
            clerkReady = true;
            clerkLoading = false;
            btnLoading(false);
            flushCallbacks();
          })
          .catch(function (err) {
            clerkLoading = false;
            btnLoading(false);
            flushCallbacks(err);
          });
      };
      script.onerror = function () {
        clerkLoading = false;
        btnLoading(false);
        flushCallbacks(new Error('Failed to load Clerk JS'));
      };
      document.head.appendChild(script);
    }

    function flushCallbacks(err) {
      var cbs = pendingCallbacks;
      pendingCallbacks = [];
      cbs.forEach(function (cb) { cb(err); });
    }

    function openDashboard() {
      accountBtn.disabled = true;
      fetch('/admin/dashboard')
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          accountBtn.disabled = false;
          if (!data || !Array.isArray(data.tabs)) return;

          var signOutHtml = '<button data-manage-account-sign-out class="tbr-btn tbr-btn-sm tbr-signout" onclick="window.Clerk.signOut({redirectUrl:\'/\'})">Sign out</button>';

          var customPages = data.tabs.map(function (tab) {
            var html = tab.html.replace(/\{\{SIGNOUT\}\}/g, signOutHtml);
            return {
              label: tab.label,
              url: tab.url,
              mount: function (el) { el.innerHTML = html; },
              unmount: function (el) { el.innerHTML = ''; },
              mountIcon: function (el) { el.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>'; },
              unmountIcon: function (el) { el.innerHTML = ''; }
            };
          });

          clerkPushAccountUrl();
          var opened = window.Clerk.openUserProfile({ customPages: customPages });
          if (opened && typeof opened.then === 'function') {
            opened.then(function () { clerkRestoreUrl(); });
          }
        })
        .catch(function (err) {
          accountBtn.disabled = false;
          console.error('[nav] dashboard fetch error:', err);
        });
    }

    function openClerkPanel(onClose) {
      clerkPushAccountUrl();
      if (window.Clerk.user) {
        openDashboard();
      } else {
        var opened = window.Clerk.openSignIn();
        if (opened && typeof opened.then === 'function') {
          opened.then(function () {
            // After sign-in, open dashboard if now signed in
            if (window.Clerk && window.Clerk.user) {
              openDashboard();
            } else if (onClose) {
              onClose();
            }
          });
        }
      }
    }

    accountBtn.addEventListener('click', function () {
      whenClerkReady(function (err) {
        if (err) { console.error('[nav]', err.message || err); return; }
        openClerkPanel();
      });
    });

    // Auto-open from /account, ?open=account, or ?signin=account
    var path = window.location.pathname;
    var search = window.location.search;
    if (path === '/account' || search.indexOf('open=account') >= 0 || search.indexOf('signin=account') >= 0) {
      // Clean up query params so they don't persist across reloads.
      if (path !== '/account') {
        history.replaceState({}, '', '/');
      }
      whenClerkReady(function (err) {
        if (err) { console.error('[nav]', err.message || err); return; }
        openClerkPanel(function () {
          clerkRestoreUrl();
        });
      });
    }
  })();

  // Dashboard script re-activation shim.
  // React's dangerouslySetInnerHTML does not execute <script> tags.
  // This shim watches for [data-tbr-script] elements and creates real <script> tags.
  (function () {
    function activate() {
      document.querySelectorAll('[data-tbr-script]').forEach(function (s) {
        if (s.dataset.tbrActivated) return;
        s.dataset.tbrActivated = '1';
        var n = document.createElement('script');
        n.textContent = s.textContent;
        document.head.appendChild(n);
      });
    }
    activate();
    new MutationObserver(activate).observe(document.body, { childList: true, subtree: true });
  })();
</script>

<style>
  .nav-auth-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 2px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    cursor: pointer;
    font: inherit;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .nav-auth-btn:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.45);
    background: rgba(215, 155, 91, 0.16);
  }

  .nav-auth-btn:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .nav-spin {
    display: inline-block;
    width: 13px;
    height: 13px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-top-color: rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    animation: nav-spin 0.6s linear infinite;
    vertical-align: middle;
  }

  @keyframes nav-spin {
    to { transform: rotate(360deg); }
  }

  .nav-auth-btn--email {
    max-width: 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>