---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ClientTabButton from './ClientTabButton.astro';
import ClientTabPanel  from './ClientTabPanel.astro';

const rawEntries = await getCollection('client-tabs');
const entries = rawEntries.sort((a: CollectionEntry<'client-tabs'>, b: CollectionEntry<'client-tabs'>) => a.id.localeCompare(b.id));
const tabs = await Promise.all(
  entries.map(async (entry: CollectionEntry<'client-tabs'>) => {
    const { Content } = await render(entry);
    const id = entry.id.replace(/^\d+-/, '');
    return { ...entry.data, id, Content };
  })
);
---

<section class="client-gs-section" id="get-started">
  <div class="container">
    <h2 class="section-heading">Grab a Client</h2>
    <div class="client-tabs" id="client-tabs">
      <div class="client-tabs__bar" role="tablist" aria-label="Client environment">
        {tabs.map((tab, i) => (
          <ClientTabButton id={tab.id} label={tab.label} active={i === 0} prefix="cgs" />
        ))}
        <div class="client-tabs__more-wrap">
          <button type="button" class="client-tabs__more-btn" id="cgs-more-btn" hidden aria-expanded="false" aria-controls="cgs-more-list">More ▾</button>
          <ul class="client-tabs__more-list" id="cgs-more-list" hidden></ul>
        </div>
      </div>

      <div class="client-panels">
        {tabs.map((tab, i) => (
          <ClientTabPanel
            id={tab.id}
            Content={tab.Content}
            active={i === 0}
            prefix="cgs"
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const barEl    = document.querySelector<HTMLElement>('.client-tabs__bar');
  const barTabs  = Array.from(document.querySelectorAll<HTMLElement>('.client-tabs__bar > [data-cgs-tab]'));
  const moreBtn  = document.getElementById('cgs-more-btn') as HTMLButtonElement | null;
  const moreList = document.getElementById('cgs-more-list') as HTMLElement | null;

  const TAB_W       = 112; // must match CSS width: 112px
  const MORE_W      = 88;  // more button + gap reserve
  const MAX_VISIBLE = 6;   // always tuck extras into More regardless of width

  const activateClientTab = (tab: HTMLElement) => {
    const targetId = tab.dataset.cgsTab as string;
    barTabs.forEach((t) => {
      const active = t === tab;
      t.classList.toggle('is-active', active);
      t.setAttribute('aria-selected', active ? 'true' : 'false');
      t.setAttribute('tabindex', active ? '0' : '-1');
    });
    moreList?.querySelectorAll<HTMLElement>('[data-cgs-mirror]').forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.cgsMirror === targetId);
    });
    document.querySelectorAll<HTMLElement>('.client-panel').forEach((panel) => {
      const active = panel.id === targetId;
      panel.classList.toggle('is-active', active);
      panel.hidden = !active;
    });
    if (moreList && !moreList.hidden) {
      moreList.hidden = true;
      moreBtn?.setAttribute('aria-expanded', 'false');
    }
  };

  const switchTab = (tab: HTMLElement) => {
    if ('startViewTransition' in document) {
      document.startViewTransition(() => activateClientTab(tab));
    } else {
      activateClientTab(tab);
    }
  };

  barTabs.forEach((tab) => tab.addEventListener('click', () => switchTab(tab)));

  const recalcTabs = () => {
    if (!barEl) return;
    const barWidth = barEl.offsetWidth;
    const fitsAll  = barWidth >= barTabs.length * TAB_W + MORE_W;
    const allFit   = fitsAll && barTabs.length <= MAX_VISIBLE;

    if (allFit) {
      barTabs.forEach((t) => { t.hidden = false; });
      if (moreBtn) moreBtn.hidden = true;
      if (moreList) moreList.innerHTML = '';
      return;
    }

    const byWidth      = Math.max(1, Math.floor((barWidth - MORE_W) / TAB_W));
    const visibleCount = Math.min(byWidth, MAX_VISIBLE);
    if (moreBtn) moreBtn.hidden = false;
    barTabs.forEach((t, i) => { t.hidden = i >= visibleCount; });

    if (moreList) {
      moreList.innerHTML = '';
      barTabs.filter((t) => t.hidden).forEach((tab) => {
        const li  = document.createElement('li');
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'client-tab';
        if (tab.classList.contains('is-active')) btn.classList.add('is-active');
        btn.dataset.cgsMirror = tab.dataset.cgsTab;
        btn.textContent = tab.textContent?.trim() ?? '';
        btn.addEventListener('click', () => activateClientTab(tab));
        li.appendChild(btn);
        moreList.appendChild(li);
      });
    }
  };

  if (barEl) new ResizeObserver(recalcTabs).observe(barEl);
  recalcTabs();

  if (moreBtn && moreList) {
    moreBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = !moreList.hidden;
      moreList.hidden = open;
      moreBtn.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
    document.addEventListener('click', (e) => {
      if (!moreList.hidden && !(e.target as Element).closest('.client-tabs__more-wrap')) {
        moreList.hidden = true;
        moreBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }

  document.getElementById('client-gs-signin')?.addEventListener('click', () => {
    document.getElementById('nav-sign-in')?.click();
  });
</script>
