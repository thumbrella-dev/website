---
interface Feature {
  title: string;
  description: string;
  detail?: string;
}

const { features = [
  {
    title: 'Docs before demos',
    description: 'Lead with the shape of the API and the hosting model instead of forcing visitors through a brand-heavy funnel.',
    detail: 'Built for developers who want the operational model first.',
  },
  {
    title: 'Media browser in the open',
    description: 'A live media library view can sit next to the docs so people can inspect the product without switching context.',
    detail: 'Good for evaluating structure, metadata, and delivery behavior.',
  },
  {
    title: 'Static-site friendly',
    description: 'The site stays simple: Astro pages, markdown-capable content, and a build that works with plain Node on a laptop.',
    detail: 'No container workflow required.',
  },
] } = Astro.props;
---

<div class="feature-grid">
  {features.map((feature) => (
    <article class="feature-card">
      <h3>{feature.title}</h3>
      <p>{feature.description}</p>
      {feature.detail && <p class="feature-card__detail">{feature.detail}</p>}
    </article>
  ))}
</div>