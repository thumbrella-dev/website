---
import Search from '@astrojs/starlight/components/Search.astro';
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import { getCollection } from 'astro:content';

const currentRoute = Astro.locals.starlightRoute;
const currentId = currentRoute.id.replace(/\/index$/, '');

const docs = await getCollection('docs');

// Build pages array with H2 headings extracted from raw markdown body.
// We can't use entry.render() because it's not available in the workerd SSR runtime.
function extractH2s(body) {
  const h2s = [];
  const re = /^##\s+(.+)$/gm;
  let m;
  while ((m = re.exec(body)) !== null) {
    const text = m[1].trim();
    // Generate a slug matching Astro/Starlight's heading slug algorithm
    const slug = text
      .toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
    h2s.push({ text, slug });
  }
  return h2s;
}

const pages = docs.map((entry) => {
  const slug = entry.id.replace(/\/index$/, '');
  const h2s = extractH2s(entry.body || '');
  return { slug, title: entry.data.title, h2s };
});

// Explicit sidebar order.
// We tried sorting by filename prefix and by frontmatter `order` —
// neither works because entry.id is the frontmatter slug, not the file path.
// This list is the source of truth; keep it synced with the files in
// src/content/docs/docs/ when adding or reordering pages.
const slugOrder = [
  'docs',
  'docs/project',
  'docs/pricing',
  'docs/sponsor',
  'docs/faq',
  'docs/client',
  'docs/server',
  'docs/cloud',
  'docs/development',
];
pages.sort((a, b) => slugOrder.indexOf(a.slug) - slugOrder.indexOf(b.slug));
---

<div class="sidebar-search">
  <Search />
</div>
<SidebarPersister>
  <nav class="sidebar-nav" aria-label="Documentation">
    <ul class="sidebar-tree">
      {pages.map((page) => {
        const isCurrent = page.slug === currentId;
        const href = page.slug === 'docs' ? '/docs/' : `/${page.slug}/`;
        return (
          <li>
            <a
              href={href}
              class:list={['sidebar-page-link', { current: isCurrent }]}
              aria-current={isCurrent ? 'page' : undefined}
            >
              {page.title}
            </a>
            {page.h2s.length > 0 && (
              <ul class="sidebar-headings">
                {page.h2s.map((h2) => (
                  <li>
                    <a href={`${href}#${h2.slug}`} class="sidebar-heading-link">
                      {h2.text}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        );
      })}
    </ul>
  </nav>
</SidebarPersister>

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>

<style>
  .sidebar-tree {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sidebar-page-link {
    display: block;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-white);
    text-decoration: none;
    transition: background 0.15s;
  }
  .sidebar-page-link:hover {
    background: var(--sl-color-gray-6);
  }
  .sidebar-page-link.current {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text-accent);
  }
  .sidebar-headings {
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem 0.875rem;
    border-left: 1px solid var(--sl-color-gray-5);
  }
  .sidebar-heading-link {
    display: block;
    padding: 0.15rem 0.75rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s;
  }
  .sidebar-heading-link:hover {
    color: var(--sl-color-white);
  }
</style>
