---
interface CarouselItem {
  name: string;
  src: string;
  resolution: string;
  codec: string;
  type: string;
  kind: string;
  duration: string;
  size: string;
  procMs: number;
  link: string;
  description: string;
  resultUrl?: string;
  resultJson?: string;
}

interface Props {
  items: CarouselItem[];
}

const { items } = Astro.props;
---

<section class="carousel-section">
  <a
    class="carousel-demo-link"
    href="https://demo.thumbrella.dev"
    target="_blank"
    rel="noopener"
  >Full gallery at demo.thumbrella.dev &rarr;</a>
  <div class="carousel-track-wrap" aria-label="Sample media thumbnails">
    <ul class="carousel-track" id="carousel-track" role="list">
      {[0, 1, 2].flatMap(() => items).map((item, i) => {
        const f = (8 * Math.PI) / items.length;  // four full wave cycles per set
        const rx = (Math.sin(i * f * 1) * 10).toFixed(1);
        const ry = (Math.cos(i * f * 1) * 13).toFixed(1);
        const ty = (Math.cos(i * f * 1) * 1).toFixed(1);
        const placeholderSrc = `https://cloud.thumbrella.dev/placeholder/${item.kind || 'unknown'}.jpeg`;
        return (
          <li
            class="ctile"
            style={`--ctile-rx: ${rx}deg; --ctile-ry: ${ry}deg; --ctile-tx: 0rem; --ctile-ty: ${ty}rem`}
            data-thumb-src={item.src}
            data-name={item.name}
            data-resolution={item.resolution}
            data-codec={item.codec}
            data-type={item.type}
            data-kind={item.kind}
            data-duration={item.duration}
            data-size={item.size}
            data-proc={item.procMs}
            data-link={item.link}
            data-description={item.description}
            data-result-url={item.resultUrl}
            data-result={item.resultJson}
          >
            <div class="ctile__thumb">
              <div class="ctile__bg" aria-hidden="true"></div>
              <div class="ctile__placeholder" aria-hidden="true">
                <img class="ctile__ph-img" src={placeholderSrc} alt="" draggable="false" />
                <span class="ctile__spinner"></span>
              </div>
              <img class="ctile__img" alt={item.name} draggable="false" />
              <div class="ctile__badges" aria-hidden="true">
                <span class={`ctile__badge ctile__badge--${item.type}`}>{item.codec}</span>
                {item.duration && <span class="ctile__badge ctile__badge--dur">{item.duration}</span>}
              </div>
            </div>
            <p class="ctile__name">{item.name}</p>
          </li>
        );
      })}
    </ul>
  </div>

  <div class="cpopup" id="cpopup" role="dialog" aria-modal="true" aria-label="Media details" aria-hidden="true">
    <p class="cpopup__filename" id="cpopup-name"></p>
    <dl class="cpopup__dl" id="cpopup-dl"></dl>
  </div>
</section>

<style is:global>
  /* CAROUSEL */
  .carousel-section {
      position: relative;
      overflow-x: clip;
  }

  .carousel-demo-link {
      position: absolute;
      top: -2rem;
      right: 1rem;
      z-index: 3;
      font-size: 0.8rem;
      font-family: var(--font-mono, 'IBM Plex Mono', monospace);
      color: rgba(205, 171, 125, 0.68);
      text-decoration: none;
      transition: color 0.15s ease;
  }

  .carousel-demo-link:hover {
      color: var(--accent-strong);
  }

  /* fade edges */
  .carousel-section::before,
  .carousel-section::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 80px;
      z-index: 2;
      pointer-events: none;
  }

  .carousel-section::before {
      left: 0;
      background: linear-gradient(to right, rgba(25, 45, 120, 0.10), transparent);
  }

  .carousel-section::after {
      right: 0;
      background: linear-gradient(to left, rgba(25, 45, 120, 0.10), transparent);
  }

  .carousel-track-wrap {
      overflow-y: visible;
      cursor: grab;
  }

  .carousel-track-wrap:active {
      cursor: grabbing;
  }

  .carousel-track {
      display: flex;
      gap: 60px;
      list-style: none;
      padding: 0.5rem 0;
      margin: 0;
      will-change: transform;
      width: max-content;
      overflow-y: visible;
  }

  /* tile  */
  .ctile {
      flex-shrink: 0;
      width: 190px;
      display: grid;
      gap: 0.4rem;
      cursor: pointer;
      border-radius: 10px;
      border: 1px solid transparent;
      padding: 6px;
      transform-style: preserve-3d;
      transform: perspective(350px) translate(var(--ctile-tx, 0px), var(--ctile-ty, 0px)) rotateX(var(--ctile-rx, 0deg)) rotateY(var(--ctile-ry, 0deg));
      transition: border-color 0.2s, background 0.2s, transform 0.45s ease;
  }

  .ctile:hover {
      border-color: rgba(200, 149, 78, 0.35);
      background: rgba(200, 149, 78, 0.06);
      transform: perspective(350px) translate(var(--ctile-tx, 0px), var(--ctile-ty, 0px)) rotateX(0deg) rotateY(0deg) scale(1.06);
  }

  .ctile__thumb {
      position: relative;
      aspect-ratio: 4 / 3;
      background: rgba(0, 0, 0, 0.4);
      border-radius: 6px;
      overflow: hidden;
  }

  /* filled background (visible when tile has no image yet) */
  .ctile__bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(45,35,65,0.9), rgba(20,15,35,0.95));
      transition: opacity 0.4s ease;
  }

  .ctile.is-loaded .ctile__bg { opacity: 0.3; }

  /* placeholder icon + spinner overlay */
  .ctile__placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      opacity: 0;
      transition: opacity 0.35s ease;
      pointer-events: none;
  }

  .ctile.is-pending .ctile__placeholder { opacity: 1; }
  .ctile.is-loaded  .ctile__placeholder { opacity: 0; }

  .ctile__ph-img {
      width: 48px;
      height: 48px;
      object-fit: contain;
      opacity: 0.7;
      filter: grayscale(0.2);
  }

  /* spinner badge — small rotating ring in bottom-right */
  .ctile__spinner {
      position: absolute;
      bottom: 6px;
      right: 6px;
      width: 18px;
      height: 18px;
      border: 2px solid rgba(200, 149, 78, 0.2);
      border-top-color: rgba(200, 149, 78, 0.8);
      border-radius: 50%;
      opacity: 0;
      transition: opacity 0.25s ease;
  }

  .ctile.is-pending .ctile__spinner {
      opacity: 1;
      animation: ctile-spin 0.9s linear infinite;
  }

  @keyframes ctile-spin {
      to { transform: rotate(360deg); }
  }

  .ctile__img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 0.45s ease;
  }

  .ctile.is-loaded .ctile__img { opacity: 1; }

  .ctile__badges {
      position: absolute;
      inset: auto 0 0;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding: 0.3rem;
      pointer-events: none;
  }

  .ctile__badge {
      padding: 0.1rem 0.38rem;
      background: rgba(0,0,0,0.68);
      border-radius: 3px;
      font-size: 0.6rem;
      font-family: var(--font-sans);
      font-weight: 600;
      letter-spacing: 0.04em;
      color: rgba(255,255,255,0.75);
      opacity: 0;
      transition: opacity 0.3s ease;
  }

  .ctile.is-loaded .ctile__badge { opacity: 1; }

  .ctile__badge--video { color: var(--accent-strong); }
  .ctile__badge--photo { color: #a0d4b0; }
  .ctile__badge--audio { color: #e0b0d0; }
  .ctile__badge--3d    { color: #c9b4f0; }
  .ctile__badge--vector { color: #f0d4a0; }
  .ctile__badge--document { color: #a0c8e0; }
  .ctile__badge--dur   { font-weight: 400; color: rgba(255,255,255,0.65); }

  .ctile__name {
      font-size: 0.8rem;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin: 0;
      padding: 0 2px;
      opacity: 0;
      transition: opacity 0.3s ease;
  }

  .ctile.is-pending .ctile__name,
  .ctile.is-loaded .ctile__name {
      opacity: 1;
  }

  /* popup  */
  .cpopup {
      position: absolute;
      z-index: 10;
      margin: 0;
      width: 22rem;
      max-height: 80vh;
      overflow-y: auto;
      background: #21193a;
      border: 1px solid rgba(200, 149, 78, 0.3);
      border-radius: 12px;
      padding: 0.9rem 1rem;
      box-shadow: 0 12px 40px rgba(0,0,0,0.55);
      font-family: var(--font-sans);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-6px);
      transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .cpopup.is-open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
  }

  .cpopup__filename {
      display: none;
  }

  .cpopup__dl {
      margin: 0;
      display: grid;
      gap: 0.35rem;
  }

  .cpopup__sec {
      display: grid;
      gap: 0.15rem;
  }

  .cpopup__sec-title {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-strong);
      margin-bottom: 0.05rem;
  }

  .cpopup__sec-title a {
      color: inherit;
      text-decoration: underline;
  }

  .cpopup__row {
      display: flex;
      justify-content: space-between;
      gap: 0.5rem;
      font-size: 0.8rem;
      padding-left: 0.8em;
  }

  .cpopup__row dt {
      color: var(--text-muted);
  }

  .cpopup__row dd {
      margin: 0;
      color: var(--text);
      font-weight: 500;
      text-align: right;
  }

  .cpopup__desc {
      margin-top: 0.35rem;
      padding-left: 0.8em;
      font-size: 0.8rem;
      color: var(--text-muted);
      white-space: normal;
      word-wrap: break-word;
      line-height: 1.4;
  }
</style>

<script>
  import { computePosition, flip, shift, offset } from '@floating-ui/dom';

  const track = document.getElementById('carousel-track') as HTMLElement | null;
  const popup = document.getElementById('cpopup') as HTMLElement | null;
  if (track) {
    const allTiles = Array.from(track.children) as HTMLElement[];
    // Tiles are rendered 3× server-side — one set width for modulo wrapping
    const setCount = allTiles.length / 3;
    const oneSetWidth = allTiles.slice(0, setCount).reduce((w, el) => w + el.offsetWidth + 120 /* gap */, 0);

    // Observe ALL tiles so each clone restarts its animation when fully on screen.
    // Reset only when fully off screen so tiles stay loaded during scroll-out.
    const enterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const el = entry.target as HTMLElement;
        const ratio = entry.intersectionRatio;

        if (ratio >= 0.99) {
          // Fully on screen — start the load simulation
          if (el.classList.contains('is-pending') || el.classList.contains('is-loaded')) return;
          const src = el.dataset.thumbSrc ?? '';
          const procMs = parseInt(el.dataset.proc ?? '0', 10);

          const loadThumb = () => {
            const img = el.querySelector<HTMLImageElement>('.ctile__img');
            if (!img || !src) return;
            el.classList.remove('is-pending');
            el.classList.add('is-loaded');
            img.addEventListener('load',  () => {}, { once: true });
            img.addEventListener('error', () => el.classList.add('is-error'), { once: true });
            img.src = src;
          };

          if (procMs < 20) {
            loadThumb();
          } else {
            el.classList.add('is-pending');
            const holdMs = Math.min(procMs, 4000);
            setTimeout(loadThumb, holdMs);
          }
        } else if (ratio === 0) {
          // Fully off screen — reset for next loop cycle
          el.classList.remove('is-pending', 'is-loaded', 'is-error');
          const img = el.querySelector<HTMLImageElement>('.ctile__img');
          if (img) img.removeAttribute('src');
        }
        // Ratios between 0 and 0.99: transitioning, do nothing.
      });
    }, { threshold: [0, 0.99] });

    allTiles.forEach((item) => enterObserver.observe(item));

    // Scroll animation with smooth ease-in/out
    const TARGET_SPEED = 62;
    const EASE_K = 3.5;
    let speed = TARGET_SPEED;
    let targetSpeed = TARGET_SPEED;
    let pos = 0;
    let lastTime: number | null = null;

    // Frame-rate monitor — disable animation if the browser can't keep up
    // (common in embedded VS Code browser and low-power devices).
    let slowFrames = 0;
    const SLOW_THRESHOLD_MS = 80;   // frame delta above this is "slow"
    const SLOW_LIMIT = 10;           // consecutive slow frames → kill animation
    let animationActive = true;

    function step(ts: number) {
      if (!animationActive) return;
      const dt = lastTime !== null ? Math.min((ts - lastTime) / 1000, 0.1) : 0;

      // Monitor frame health
      if (lastTime !== null && (ts - lastTime) > SLOW_THRESHOLD_MS) {
        slowFrames++;
        if (slowFrames >= SLOW_LIMIT) {
          animationActive = false;
          return;
        }
      } else {
        slowFrames = Math.max(0, slowFrames - 1);
      }

      lastTime = ts;
      speed += (targetSpeed - speed) * (1 - Math.exp(-EASE_K * dt));
      if (speed > 0.3 && track && oneSetWidth > 0) {
        pos += speed * dt;
        if (pos >= oneSetWidth) pos -= oneSetWidth;
        // Reset to 0 periodically to avoid unbounded float growth
        if (pos > 100000) pos = 0;
        track.style.transform = `translateX(${-pos}px)`;
      }
      requestAnimationFrame(step);
    }
    requestAnimationFrame(step);

    // Pause on hover
    let hovering = false;
    track.parentElement?.addEventListener('mouseenter', () => {
      hovering = true;
      targetSpeed = 0;
    });
    track.parentElement?.addEventListener('mouseleave', () => {
      hovering = false;
      if (!popup || !popup.classList.contains('is-open')) targetSpeed = TARGET_SPEED;
    });

    //  Drag / swipe 
    const trackWrap = track.parentElement as HTMLElement | null;
    let dragging = false;
    let dragStartX = 0;
    let dragStartPos = 0;
    let dragMoved = false;

    function onPointerDown(e: PointerEvent) {
      if (e.pointerType === 'mouse' && e.button !== 0) return; // left-click only
      dragging = true;
      dragMoved = false;
      dragStartX = e.clientX;
      dragStartPos = pos;
      targetSpeed = 0;
      speed = 0;
    }

    function onPointerMove(e: PointerEvent) {
      if (!dragging) return;
      const dx = e.clientX - dragStartX;
      if (Math.abs(dx) < 2) return; // dead zone to avoid jitter
      // Only capture the pointer once the user actually drags, so that
      // stationary clicks still reach the tiles to open the popup.
      if (!dragMoved) trackWrap?.setPointerCapture(e.pointerId);
      dragMoved = true;
      pos = dragStartPos - dx;
      if (oneSetWidth > 0) {
        // Wrap position within one set
        while (pos < 0) pos += oneSetWidth;
        while (pos >= oneSetWidth) pos -= oneSetWidth;
      }
      if (track) track.style.transform = `translateX(${-pos}px)`;
    }

    function onPointerUp(_e: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      if (dragMoved) trackWrap?.releasePointerCapture((_e as PointerEvent).pointerId);
      if (!popup?.classList.contains('is-open')) targetSpeed = TARGET_SPEED;
    }

    trackWrap?.addEventListener('pointerdown', onPointerDown);
    trackWrap?.addEventListener('pointermove', onPointerMove);
    trackWrap?.addEventListener('pointerup', onPointerUp);
    trackWrap?.addEventListener('pointercancel', onPointerUp);

    // Prevent text selection while dragging
    trackWrap?.addEventListener('selectstart', (e) => {
      if (dragging) e.preventDefault();
    });

    // Prevent native image drag-and-drop
    trackWrap?.addEventListener('dragstart', (e) => e.preventDefault());

    //  Popup: dynamic fields from result JSON 

    /** Escape HTML entities so raw text is safe to embed. */
    function escHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    /** Render the demo site's "poor man's markdown" (same as generate-index.js). */
    function renderInlineMd(text: string): string {
      return escHtml(text)
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/__([^_]+)__/g, '<u>$1</u>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        .replace(/_([^_]+)_/g, '<em>$1</em>');
    }

    function formatSize(bytes: number): string {
      let unit = "kb";
      if (bytes >= 1e9) {
        bytes = bytes / 1e9;
        unit = "gb";
      }
      else if (bytes >= 1e6) {
        bytes = bytes / 1e6;
        unit = "mb";
      }
      else {
        bytes = bytes / 1e3;
        unit = "kb";
      }
      let clean = "";
      if (bytes < 10) {
        clean = bytes.toFixed(1);
      }
      else {
        clean = bytes.toFixed(0);
      }
      
      return `${clean} ${unit}`;
    }

    function formatMs(s: number): string {
      if (s >= 1) return `${s.toFixed(1)}s`;
      return `${Math.round(s * 1000)} ms`;
    }

    function formatChannels(channels: number): string {
      if (channels == 0) {
        return "";
      }
      if (channels == 1) {
        return "mono";
      }
      if (channels == 2) {
        return "stereo";
      }
      return `${channels} channels`;
    }

    function buildPropsLine(props: Record<string, unknown>): string {
      const parts: string[] = [];
      const p = props as Record<string, number | string | undefined>;

      if (p.width_pixels && p.height_pixels) {
        parts.push(`${p.width_pixels}\u00D7${p.height_pixels}`);
      }
      if (p.bits_per_pixel != null) parts.push(`${p.bits_per_pixel}bpp`);
      if (p.duration_seconds != null) parts.push(`${Number(p.duration_seconds).toFixed(1)} sec`);
      if (p.channel_count != null) parts.push(formatChannels(p.channel_count));
      if (p.up_axis) parts.push(String(p.up_axis));
      if (p.camera_azimuth_deg != null) parts.push(`${p.camera_azimuth_deg}\u00B0`);
      if (p.camera_elevation_deg != null) parts.push(`${p.camera_elevation_deg}\u00B0`);
      if (p.base_color) parts.push(String(p.base_color));

      return parts.join(' ∙ ');
    }

    track.addEventListener('click', async (e) => {
      if (dragMoved) return; // suppress click after drag
      const tile = (e.target as Element).closest('.ctile[data-name]') as HTMLElement | null;
      if (!tile || !popup) return;

      targetSpeed = 0;
      const dl = document.getElementById('cpopup-dl');
      const nameEl = document.getElementById('cpopup-name');
      if (nameEl) nameEl.textContent = '';

      if (dl) {
        dl.innerHTML = '';

        // Lazy-fetch the full result JSON if not already cached on the tile.
        let raw = tile.dataset.result;
        if (!raw) {
          const resultUrl = tile.dataset.resultUrl;
          if (resultUrl) {
            try {
              const res = await fetch(resultUrl);
              if (res.ok) {
                raw = await res.text();
                tile.dataset.result = raw;   // cache for subsequent clicks
              }
            } catch { /* network error, show empty popup */ }
          }
        }

        if (raw) {
          try {
            const data = JSON.parse(raw);
            const r = (data.result ?? data) as Record<string, unknown>;
            const media = (r.media ?? {}) as Record<string, unknown>;
            const props = (media.properties ?? {}) as Record<string, unknown>;

            //  Thumbrella section 
            const tbr = document.createElement('div');
            tbr.className = 'cpopup__sec';
            const resultUrl = tile.dataset.resultUrl ?? '';
            tbr.innerHTML = `<dt class="cpopup__sec-title"><a href="${resultUrl}">Thumbrella</a></dt>`;
            if (r.duration != null) {
              tbr.innerHTML += `<div class="cpopup__row"><dt>Rendered in</dt><dd>${formatMs(Number(r.duration))}</dd></div>`;
            }
            if (r.download_size != null) {
              tbr.innerHTML += `<div class="cpopup__row"><dt>Network fetch</dt><dd>${formatSize(Number(r.download_size))}</dd></div>`;
            }
            dl.appendChild(tbr);

            //  Media section 
            const msec = document.createElement('div');
            msec.className = 'cpopup__sec';
            const url = String(r.url ?? '');
            const kind = String(media.kind ?? '');
            const ext = (String(media.extension ?? '')).toLowerCase();
            const size = media.file_size != null ? formatSize(Number(media.file_size)) : '';
            const kindExt = [ext, kind].filter(Boolean).join(' ');
            msec.innerHTML = `<dt class="cpopup__sec-title"><a href="${url}">Media</a></dt>`;

            if (size || kindExt) {
              const line1 = [size, kindExt].filter(Boolean).join(' ∙ ');
              msec.innerHTML += `<div class="cpopup__row"><dt>File</dt><dd>${line1}</dd></div>`;
            }

            const propsLine = buildPropsLine(props);
            if (propsLine) {
              msec.innerHTML += `<div class="cpopup__row"><dt>Properties</dt><dd>${propsLine}</dd></div>`;
            }

            dl.appendChild(msec);

            //  About section 
            const link = tile.dataset.link;
            const desc = tile.dataset.description;
            if (link || desc) {
              const asec = document.createElement('div');
              asec.className = 'cpopup__sec';
              if (link) {
                asec.innerHTML = `<dt class="cpopup__sec-title"><a href="${link}">About</a></dt>`;
              } else
              {
                asec.innerHTML = '<dt class="cpopup__sec-title">About</dt>';
              }
              if (desc) {
                asec.innerHTML += `<div class="cpopup__desc">${renderInlineMd(desc)}</div>`;
              }
              dl.appendChild(asec);
            }
          } catch { /* ignore parse errors */ }
        }
      }

      popup.classList.add('is-open');
      popup.setAttribute('aria-hidden', 'false');
      const { x, y } = await computePosition(tile, popup, {
        strategy: 'absolute',
        placement: 'bottom',
        middleware: [offset(10), shift({ padding: 8 })],
      });
      Object.assign(popup.style, { left: `${x}px`, top: `${y}px` });
    });

    // Close popup
    const closePopup = () => {
      if (!popup) return;
      popup.classList.remove('is-open');
      popup.setAttribute('aria-hidden', 'true');
      if (!document.querySelector('.cl-modalBackdrop') && !hovering) targetSpeed = TARGET_SPEED;
    };
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePopup(); });
    document.addEventListener('click', (e) => {
      if (popup?.classList.contains('is-open') &&
          !(e.target as Element).closest('.cpopup') &&
          !(e.target as Element).closest('.ctile')) {
        closePopup();
      }
    });

    // Auto-close popup when carousel section scrolls off-screen
    const carouselSection = track.closest('.carousel-section');
    if (carouselSection) {
      const visibilityObserver = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting && popup?.classList.contains('is-open')) {
            closePopup();
          }
        }
      }, { threshold: 0 });
      visibilityObserver.observe(carouselSection);
    }

    // Pause while any Clerk modal is open
    let clerkModalOpen = false;
    new MutationObserver(() => {
      const nowOpen = !!document.querySelector('.cl-modalBackdrop');
      if (nowOpen === clerkModalOpen) return;
      clerkModalOpen = nowOpen;
      if (nowOpen) {
        targetSpeed = 0;
      } else if (!track.parentElement?.matches(':hover')) {
        targetSpeed = TARGET_SPEED;
      }
    }).observe(document.body, { childList: true, subtree: true });
  }
</script>
