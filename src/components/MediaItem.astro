---
export interface Props {
  name: string;
  src: string;
  resolution: string;
  codec: string;
  type: 'video' | 'photo' | 'raw';
  duration?: string;
  delay?: number;
}

const { name, src, resolution, codec, type, duration, delay = 600 } = Astro.props;
---

<div class="mitem" data-thumb-src={src} data-thumb-delay={delay}>
  <div class="mitem__thumb" aria-label={name} role="img">
    <div class="mitem__shimmer" aria-hidden="true"></div>
    <img class="mitem__img" alt={name} />
    <div class="mitem__badges" aria-hidden="true">
      <span class={`mitem__badge mitem__badge--type mitem__badge--${type}`}>{codec}</span>
      {duration && <span class="mitem__badge mitem__badge--dur">{duration}</span>}
    </div>
  </div>
  <div class="mitem__caption">
    <span class="mitem__name">{name}</span>
    <span class="mitem__meta">{resolution} · {codec}</span>
  </div>
</div>
