---
---

<section class="hp-section hp-section--no-border">
  <div class="container">
    <h2 class="section-heading">News</h2>
    <div class="caps-panel">
      <ul class="news-list" id="news-list"></ul>
      <p class="news-footer">
        <a href="https://github.com/orgs/thumbrella-dev/discussions/categories/news">View all discussions &rarr;</a>
      </p>
    </div>
  </div>
</section>

<script>
  interface NewsItem {
    title: string;
    url: string;
    updatedAt: string;
    bodyPreview: string;
  }

  function relativeTime(iso: string): string {
    const diff = Date.now() - new Date(iso).getTime();
    const secs = Math.floor(diff / 1000);
    if (secs < 40) return 'just now';
    if (secs < 100) return 'a minute ago';
    const mins = Math.floor(secs / 60);
    if (mins < 40) return `${mins} minutes ago`;
    if (mins < 100) return 'an hour ago';
    const hours = Math.floor(mins / 60);
    if (hours < 22) return `${hours} hours ago`;
    if (hours < 40) return 'a day ago';
    const days = Math.floor(hours / 24);
    if (days < 26) return `${days} days ago`;
    if (days < 50) return 'a month ago';
    const months = Math.floor(days / 30);
    return `${months} months ago`;
  }

  function renderNews(items: NewsItem[]): void {
    const list = document.getElementById('news-list');
    if (!list) return;

    if (items.length === 0) {
      list.innerHTML = '<li class="news-footer" style="list-style:none">No recent news.</li>';
      return;
    }

    list.innerHTML = items
      .map(
        (item) => `
        <li class="news-item">
          <div class="news-line1">
            <a class="news-title" href="${item.url}">${item.title}</a>
            <span class="news-date">${relativeTime(item.updatedAt)}</span>
          </div>
          ${item.bodyPreview ? `<p class="news-preview">${item.bodyPreview}</p>` : ''}
        </li>`
      )
      .join('');
  }

  fetch('/api/news')
    .then((res) => res.json())
    .then((data: NewsItem[]) => renderNews(data))
    .catch(() => renderNews([]));
</script>

<style is:global>
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .news-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 0.48rem;
  }

  .news-line1 {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-weight: 600;
  }

  .news-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    line-height: 1.35;
    flex: 1;
    min-width: 0;
  }

  .news-title:hover {
    color: var(--accent-strong);
    text-decoration: underline;
  }

  .news-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .news-preview {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
    padding-left: 0.8em;
    line-height: 1.6;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .news-footer {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
    padding-top: 0.85rem;
  }


  .news-footer a {
    color: var(--accent-strong);
    text-decoration: none;
  }

  .news-footer a:hover {
    text-decoration: underline;
  }
</style>
