---
interface NewsItem {
  title: string;
  url: string;
  updatedAt: string;
  commentCount: number;
  reactions: Record<string, number>;
}

let items: NewsItem[] = [];
try {
  const res = await fetch(`${Astro.url.origin}/worker/news`);
  if (res.ok) {
    items = await res.json();
  }
} catch { /* skip */ }


---

<section class="hp-section hp-section--no-border">
  <div class="container">
    <h2 class="client-gs__heading">
      <a href="https://github.com/orgs/thumbrella-dev/discussions/categories/news" target="_blank" rel="noopener">News</a>
    </h2>
    <div class="caps-panel">
    {items.length > 0 ? (
    <ul class="news-list">
      {items.map((item) => {
        const date = new Date(item.updatedAt);
        const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        const reactionStr = Object.entries(item.reactions)
          .map(([emoji, count]) => `${emoji} ${count}`)
          .join(' ');
        return (
          <li class="news-item">
            <a class="news-title" href={item.url} target="_blank" rel="noopener">{item.title}</a>
            <span class="news-meta">
              <time datetime={item.updatedAt}>{dateStr}</time>
              {item.commentCount > 0 && <span class="news-comments">{item.commentCount} comment{item.commentCount !== 1 ? 's' : ''}</span>}
              {reactionStr && <span class="news-reactions">{reactionStr}</span>}
            </span>
          </li>
        );
      })}
    </ul>
  ) : (
    <p class="news-empty">No recent news. <a href="https://github.com/orgs/thumbrella-dev/discussions/categories/news" target="_blank" rel="noopener">View all discussions &rarr;</a></p>
  )}
    </div>
  </div>
</section>

<style is:global>
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .news-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .news-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    line-height: 1.35;
  }

  .news-title:hover {
    color: var(--accent-strong);
    text-decoration: underline;
  }

  .news-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .news-comments,
  .news-reactions {
    color: rgba(255, 255, 255, 0.45);
  }

  .news-empty {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
  }

  .news-empty a {
    color: var(--accent-strong);
    text-decoration: none;
  }

  .news-empty a:hover {
    text-decoration: underline;
  }
</style>
