---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ClientTabButton from './ClientTabButton.astro';
import ClientTabPanel  from './ClientTabPanel.astro';

const rawEntries = await getCollection('hosting-tabs');
const entries = rawEntries.sort((a: CollectionEntry<'hosting-tabs'>, b: CollectionEntry<'hosting-tabs'>) => a.id.localeCompare(b.id));
const tabs = await Promise.all(
  entries.map(async (entry: CollectionEntry<'hosting-tabs'>) => {
    const { Content } = await render(entry);
    const id = entry.id.replace(/^\d+-/, '');
    return { ...entry.data, id, Content };
  })
);
---

<section class="client-gs-section" id="get-hosting">
  <div class="container">
    <h2 class="client-gs__heading">Start Hosting</h2>
    <div class="client-tabs" id="hosting-tabs">
      <div class="hosting-tabs__bar" role="tablist" aria-label="Hosting option">
        {tabs.map((tab, i) => (
          <ClientTabButton id={tab.id} label={tab.label} active={i === 0} prefix="hst" />
        ))}
        <div class="client-tabs__more-wrap">
          <button type="button" class="client-tabs__more-btn" id="hst-more-btn" hidden aria-expanded="false" aria-controls="hst-more-list">More \u25be</button>
          <ul class="client-tabs__more-list" id="hst-more-list" hidden></ul>
        </div>
      </div>

      <div class="client-panels">
        {tabs.map((tab, i) => (
          <ClientTabPanel
            id={tab.id}
            Content={tab.Content}
            active={i === 0}
            prefix="hst"
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const barEl    = document.querySelector<HTMLElement>('.hosting-tabs__bar');
  const barTabs  = Array.from(document.querySelectorAll<HTMLElement>('.hosting-tabs__bar > [data-hst-tab]'));
  const moreBtn  = document.getElementById('hst-more-btn') as HTMLButtonElement | null;
  const moreList = document.getElementById('hst-more-list') as HTMLElement | null;

  const TAB_W  = 112;
  const MORE_W = 88;

  const activateTab = (tab: HTMLElement) => {
    const targetId = tab.dataset.hstTab as string;
    barTabs.forEach((t) => {
      const active = t === tab;
      t.classList.toggle('is-active', active);
      t.setAttribute('aria-selected', active ? 'true' : 'false');
      t.setAttribute('tabindex', active ? '0' : '-1');
    });
    moreList?.querySelectorAll<HTMLElement>('[data-hst-mirror]').forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.hstMirror === targetId);
    });
    document.querySelectorAll<HTMLElement>('.hst-panel').forEach((panel) => {
      const active = panel.id === targetId;
      panel.classList.toggle('is-active', active);
      panel.hidden = !active;
    });
    if (moreList && !moreList.hidden) {
      moreList.hidden = true;
      moreBtn?.setAttribute('aria-expanded', 'false');
    }
  };

  barTabs.forEach((tab) => tab.addEventListener('click', () => activateTab(tab)));

  const recalcTabs = () => {
    if (!barEl) return;
    const barWidth = barEl.offsetWidth;
    const allFit = barWidth >= barTabs.length * TAB_W + MORE_W;

    if (allFit) {
      barTabs.forEach((t) => { t.hidden = false; });
      if (moreBtn) moreBtn.hidden = true;
      if (moreList) moreList.innerHTML = '';
      return;
    }

    const visibleCount = Math.max(1, Math.floor((barWidth - MORE_W) / TAB_W));
    if (moreBtn) moreBtn.hidden = false;
    barTabs.forEach((t, i) => { t.hidden = i >= visibleCount; });

    if (moreList) {
      moreList.innerHTML = '';
      barTabs.filter((t) => t.hidden).forEach((tab) => {
        const li  = document.createElement('li');
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'client-tab';
        if (tab.classList.contains('is-active')) btn.classList.add('is-active');
        btn.dataset.hstMirror = tab.dataset.hstTab;
        btn.textContent = tab.textContent?.trim() ?? '';
        btn.addEventListener('click', () => activateTab(tab));
        li.appendChild(btn);
        moreList.appendChild(li);
      });
    }
  };

  if (barEl) new ResizeObserver(recalcTabs).observe(barEl);
  recalcTabs();

  if (moreBtn && moreList) {
    moreBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = !moreList.hidden;
      moreList.hidden = open;
      moreBtn.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
    document.addEventListener('click', (e) => {
      if (!moreList.hidden && !(e.target as Element).closest('.client-tabs__more-wrap')) {
        moreList.hidden = true;
        moreBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
