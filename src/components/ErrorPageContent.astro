---
interface Props {
    code: string;
    title: string;
    message: string;
}

const { code, title, message } = Astro.props;
---

<section class="error-page">
    <div class="container error-page__inner">
        <p class="error-page__code" aria-hidden="true">{code}</p>
        <h1>{title}</h1>
        <p class="error-page__message">{message}</p>
        <div class="error-page__actions">
            <a href="/" class="button">Back home</a>
            <a href="/docs" class="button button--ghost">Documentation</a>
        </div>
    </div>
</section>
