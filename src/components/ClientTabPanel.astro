---
import { Code } from 'astro:components';

interface Props {
  /** Short id like 'js', 'python' */
  id: string;
  /** HTML string — may contain inline <code> tags */
  lede: string;
  install?: string;
  usage?: string;
  lang?: string;
  active?: boolean;
  /** Namespace prefix — must match the paired ClientTabButton. Defaults to 'cgs'. */
  prefix?: string;
}
const { id, lede, install, usage, lang = 'sh', active = false, prefix = 'cgs' } = Astro.props;
const panelId = `${prefix}-${id}`;
const tabId   = `${prefix}-tab-${id}`;
---
<div
  id={panelId}
  role="tabpanel"
  aria-labelledby={tabId}
  class:list={[`${prefix}-panel`, active && 'is-active']}
  hidden={!active}
>
  <p class="client-panel__lede" set:html={lede} />
  {install && <Code code={install} lang="sh" theme="github-dark" />}
  {usage   && <Code code={usage}   lang={lang} theme="github-dark" />}
</div>
