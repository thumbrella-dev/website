---
interface Props {
  /** Short id like 'js', 'python' */
  id: string;
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  Content: any;
  active?: boolean;
  /** Namespace prefix — must match the paired ClientTabButton. Defaults to 'cgs'. */
  prefix?: string;
}
const { id, Content, active = false, prefix = 'cgs' } = Astro.props;
const panelId = `${prefix}-${id}`;
const tabId   = `${prefix}-tab-${id}`;
---
<div
  id={panelId}
  role="tabpanel"
  aria-labelledby={tabId}
  class:list={[`${prefix}-panel`, active && 'is-active']}
  hidden={!active}
>
  <div class="client-panel__body">
    <Content />
  </div>
</div>
