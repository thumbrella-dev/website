{
  "name": "thumbrella-web",
  "version": "1.0.0",
  "description": "Project website and documentation for Thumbrella thumbnail platform.",
  "homepage": "https://thumbrella.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterShinners/thumbrella-web"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:wrangler": "astro build && wrangler dev --no-bundle",
    "deploy": "astro build --logLevel warn && wrangler deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "thumbrella",
    "thumbnails",
    "media",
    "documentation"
