  "license": "Apache-2.0",
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.0",
    "@floating-ui/dom": "^1.7.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "wrangler": "^4.105.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
